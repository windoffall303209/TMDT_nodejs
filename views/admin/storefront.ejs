<%# Trang quản lí trang web: chọn từng nhóm cấu hình trước khi chỉnh. %>
<%- include('../partials/admin-header', {
    currentPage: 'storefront',
    pageStyles: ['/css/admin/storefront.css']
}) %>

<%
    const currentSettings = settings || {};
    const currentActiveSection = typeof activeSection !== 'undefined' ? activeSection : '';
    const websiteManagementItems = [
        {
            key: 'appearance',
            title: 'Quản lí giao diện',
            description: 'Số cột sản phẩm và số danh mục nổi bật trên storefront.'
        },
        {
            key: 'jwt',
            title: 'Quản lí thời gian lưu JWT',
            description: 'Thời hạn token đăng nhập mặc định của hệ thống.'
        },
        {
            key: 'payment',
            title: 'Quản lí thời gian chờ thanh toán',
            description: 'Thời hạn thanh toán cho đơn VNPay và MoMo.'
        },
        {
            key: 'email',
            title: 'Quản lí email mặc định web',
            description: 'Email nhận mã xác thực cho thao tác quản trị nhạy cảm.'
        }
    ];
%>

<div class="admin-page" data-website-management data-active-section="<%= currentActiveSection %>">
    <div class="container">
        <div class="admin-page-header">
            <div class="admin-page-header__left">
                <h1>Quản lí trang web</h1>
            </div>
        </div>

        <% if (notice) { %>
            <div class="storefront-notice storefront-notice--<%= noticeType === 'error' ? 'error' : (noticeType === 'warning' ? 'warning' : 'success') %>">
                <%= notice %>
            </div>
        <% } %>

        <div class="website-management-menu" data-website-menu>
            <% websiteManagementItems.forEach((item) => { %>
                <button type="button" class="website-management-card" data-website-section-target="<%= item.key %>">
                    <span><%= item.title %></span>
                    <small><%= item.description %></small>
                </button>
            <% }) %>
        </div>

        <section class="admin-section website-management-panel" data-website-section="appearance" hidden>
            <button type="button" class="admin-btn admin-btn--ghost website-management-back" data-website-back>Quay lại</button>
            <h3 class="admin-section__title">Quản lí giao diện</h3>
            <form action="/admin/storefront" method="POST" class="admin-form storefront-settings-form">
                <input type="hidden" name="active_section" value="appearance">
                <div class="storefront-settings-grid">
                    <div class="storefront-settings-card">
                        <label class="admin-form__label" for="productGridColumns">Số sản phẩm mỗi hàng desktop</label>
                        <input
                            id="productGridColumns"
                            type="number"
                            name="product_grid_columns"
                            class="admin-form__input"
                            min="2"
                            max="6"
                            required
                            value="<%= currentSettings.product_grid_columns || 5 %>"
                        >
                    </div>

                    <div class="storefront-settings-card">
                        <label class="admin-form__label" for="homeCategoryShowcaseCount">Số danh mục nổi bật trang chủ</label>
                        <input
                            id="homeCategoryShowcaseCount"
                            type="number"
                            name="home_category_showcase_count"
                            class="admin-form__input"
                            min="1"
                            max="8"
                            required
                            value="<%= currentSettings.home_category_showcase_count || 3 %>"
                        >
                    </div>
                </div>

                <div class="admin-form__actions">
                    <button type="submit" class="admin-btn admin-btn--primary">Lưu cài đặt</button>
                </div>
            </form>
        </section>

        <section class="admin-section website-management-panel" data-website-section="jwt" hidden>
            <button type="button" class="admin-btn admin-btn--ghost website-management-back" data-website-back>Quay lại</button>
            <h3 class="admin-section__title">Quản lí thời gian lưu JWT</h3>
            <form action="/admin/storefront" method="POST" class="admin-form storefront-settings-form">
                <input type="hidden" name="active_section" value="jwt">
                <div class="storefront-settings-card">
                    <label class="admin-form__label" for="jwtExpireMinutes">Thời gian lưu JWT (phút)</label>
                    <input
                        id="jwtExpireMinutes"
                        type="number"
                        name="jwt_expire_minutes"
                        class="admin-form__input"
                        min="5"
                        max="43200"
                        required
                        value="<%= currentSettings.jwt_expire_minutes || 60 %>"
                    >
                    <p class="storefront-settings-card__hint">Giá trị này được lưu để quản trị cấu hình. Nếu hệ thống đang dùng biến môi trường JWT_EXPIRE, hãy đồng bộ giá trị khi triển khai.</p>
                </div>
                <div class="admin-form__actions">
                    <button type="submit" class="admin-btn admin-btn--primary">Lưu thời gian JWT</button>
                </div>
            </form>
        </section>

        <section class="admin-section website-management-panel" data-website-section="payment" hidden>
            <button type="button" class="admin-btn admin-btn--ghost website-management-back" data-website-back>Quay lại</button>
            <h3 class="admin-section__title">Quản lí thời gian chờ thanh toán</h3>
            <form action="/admin/storefront" method="POST" class="admin-form storefront-settings-form">
                <input type="hidden" name="active_section" value="payment">
                <div class="storefront-settings-card">
                    <label class="admin-form__label" for="paymentWindowHours">Thời gian chờ thanh toán online (giờ)</label>
                    <input
                        id="paymentWindowHours"
                        type="number"
                        name="payment_window_hours"
                        class="admin-form__input"
                        min="1"
                        max="168"
                        required
                        value="<%= currentSettings.payment_window_hours || 24 %>"
                    >
                    <p class="storefront-settings-card__hint">Áp dụng cho đơn hàng mới dùng VNPay hoặc MoMo cần thanh toán.</p>
                </div>
                <div class="admin-form__actions">
                    <button type="submit" class="admin-btn admin-btn--primary">Lưu thời gian thanh toán</button>
                </div>
            </form>
        </section>

        <section class="admin-section website-management-panel" data-website-section="email" hidden>
            <button type="button" class="admin-btn admin-btn--ghost website-management-back" data-website-back>Quay lại</button>
            <h3 class="admin-section__title">Quản lí email mặc định web</h3>
            <form action="/admin/storefront" method="POST" class="admin-form storefront-settings-form">
                <input type="hidden" name="active_section" value="email">
                <div class="storefront-settings-card">
                    <label class="admin-form__label" for="defaultWebEmail">Email mặc định</label>
                    <input
                        id="defaultWebEmail"
                        type="email"
                        name="default_web_email"
                        class="admin-form__input"
                        required
                        value="<%= currentSettings.default_web_email || 'nvuthanh4@gmail.com' %>"
                    >
                    <p class="storefront-settings-card__hint">Email này nhận mã xác thực khi xóa hàng loạt sản phẩm hoặc danh mục.</p>
                </div>
                <div class="admin-form__actions">
                    <button type="submit" class="admin-btn admin-btn--primary">Lưu email mặc định</button>
                </div>
            </form>
        </section>
    </div>
</div>

<script src="/js/admin/storefront.js"></script>

<%- include('../partials/admin-footer') %>
