<%# Template admin render màn quản trị sản phẩm với dữ liệu từ controller quản trị. %>
<%- include('../partials/admin-header', { currentPage: 'products', pageStyles: ['/css/admin/products.css'] }) %>

<div class="admin-page">
    <div class="container">
        <!-- Tiêu đề trang + tổng quan số lượng sản phẩm -->
        <div class="admin-page-header">
            <div class="admin-page-header__left">
                <h1>Quản Lý Sản Phẩm</h1>
            </div>
            <div class="admin-page-header__actions admin-page-header__actions--compact">
                <a
                    href="/admin/products/export<%= searchQuery ? ('?search=' + encodeURIComponent(searchQuery)) : '' %>"
                    class="admin-btn admin-btn--ghost"
                    data-product-action="export-products"
                >Xuất sản phẩm</a>
                <a href="/admin/products/import-template" class="admin-btn admin-btn--ghost">Tải mẫu</a>
                <button
                    type="button"
                    class="admin-btn admin-btn--danger admin-btn--compact-danger"
                    data-product-action="delete-all-products"
                    data-total-product-count="<%= totalProductCount || 0 %>"
                >
                    Xóa tất cả
                </button>
            </div>
        </div>

        <!-- Các thẻ thống kê nhanh -->
        <div class="stats-grid">
            <div class="stat-card stat-card--blue">
                <h3 class="stat-card__label">Tổng sản phẩm</h3>
                <p class="stat-card__value"><%= productStats ? productStats.total : 0 %></p>
            </div>
            <div class="stat-card stat-card--green">
                <h3 class="stat-card__label">Còn hàng</h3>
                <p class="stat-card__value"><%= productStats ? productStats.inStock : 0 %></p>
            </div>
            <div class="stat-card stat-card--pink">
                <h3 class="stat-card__label">Hết hàng</h3>
                <p class="stat-card__value"><%= productStats ? productStats.outOfStock : 0 %></p>
            </div>
            <div class="stat-card stat-card--purple">
                <h3 class="stat-card__label">Danh mục</h3>
                <p class="stat-card__value"><%= productStats ? productStats.categories : 0 %></p>
            </div>
        </div>

        <div class="admin-toolbar">
            <div class="admin-toolbar__info">
                <p class="admin-toolbar__title">Tìm sản phẩm cần chỉnh sửa</p>
                <% if (searchQuery) { %>
                    <p class="admin-toolbar__text">Đang lọc với từ khóa: "<strong><%= searchQuery %></strong>"</p>
                <% } %>
            </div>
            <form action="/admin/products" method="GET" class="admin-search-form">
                <input type="hidden" name="limit" value="<%= pagination ? pagination.limit : 10 %>">
                <input
                    type="search"
                    name="search"
                    value="<%= searchQuery || '' %>"
                    class="admin-form__input admin-search-form__input"
                    placeholder="Tìm theo tên, SKU..."
                >
                <div class="admin-search-form__actions">
                    <button type="submit" class="admin-btn admin-btn--primary">Tìm kiếm</button>
                    <% if (searchQuery) { %>
                        <a href="/admin/products?limit=<%= pagination ? pagination.limit : 10 %>" class="admin-btn admin-btn--ghost">Xóa lọc</a>
                    <% } %>
                </div>
            </form>
        </div>

        <div class="admin-section admin-section--collapsible<%= bulkImportResult ? ' is-open' : '' %>">
            <h3 class="admin-section__title admin-section__title--toggle" data-admin-toggle="section">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                    <polyline points="17 8 12 3 7 8"/>
                    <line x1="12" y1="3" x2="12" y2="15"/>
                </svg>
                Import H&agrave;ng Lo&#7841;t T&#7915; Excel
                <svg class="admin-section__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="6 9 12 15 18 9"/>
                </svg>
            </h3>
            <div class="admin-section__content">
                <div class="admin-toolbar admin-toolbar--import">
                    <div class="admin-toolbar__info">
                        <p class="admin-toolbar__title">Workbook + ZIP ảnh</p>
                        <p class="admin-toolbar__text">
                            Dùng 3 sheet <strong>Products</strong>, <strong>Images</strong>, <strong>Variants</strong>.
                            Excel chỉ cần ghi tên file ảnh; ảnh thật đi kèm trong file <strong>.zip</strong> để gắn cho sản phẩm và biến thể.
                        </p>
                    </div>
                    <div class="admin-search-form__actions">
                        <a href="/admin/products/import-template" class="admin-btn admin-btn--ghost">Tải file mẫu</a>
                    </div>
                </div>
                <form action="/admin/products/import" method="POST" enctype="multipart/form-data" class="admin-form">
                    <div class="admin-form__row">
                        <div class="admin-form__group">
                            <label class="admin-form__label">File Excel <span>*</span></label>
                            <input type="file" name="import_file" accept=".xlsx,.xls" required class="admin-form__input">
                            <small class="admin-form__hint">Hỗ trợ `.xlsx` và `.xls`.</small>
                        </div>
                        <div class="admin-form__group">
                            <label class="admin-form__label">ZIP ảnh</label>
                            <input type="file" name="images_zip" accept=".zip" class="admin-form__input">
                            <small class="admin-form__hint">Dùng khi workbook tham chiếu tới `image_file`. Nếu dùng `image_url` thì có thể bỏ trống.</small>
                        </div>
                    </div>
                    <div class="admin-form__actions">
                        <button type="submit" class="admin-btn admin-btn--primary">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                                <polyline points="17 8 12 3 7 8"/>
                                <line x1="12" y1="3" x2="12" y2="15"/>
                            </svg>
                            Ch&#7841;y Import
                        </button>
                    </div>
                </form>

                <div class="admin-form__hint admin-form__hint--import-rules">
                    <strong>Quy &#432;&#7899;c nhanh:</strong><br>
                    `Products`: `product_key`, `name`, `category_name` ho&#7863;c `category_id`, `price`.<br>
                    `Images`: m&#7895;i d&ograve;ng l&agrave; 1 &#7843;nh, g&#7855;n theo `product_key`.<br>
                    `Variants`: m&#7895;i d&ograve;ng l&agrave; 1 bi&#7871;n th&#7875;, c&oacute; th&#7875; g&aacute;n `image_file` ri&ecirc;ng.<br>
                    C&ugrave;ng m&#7897;t `product_key` c&oacute; th&#7875; c&oacute; nhi&#7873;u &#7843;nh v&agrave; nhi&#7873;u bi&#7871;n th&#7875;.
                </div>

                <% if (bulkImportResult) { %>
                    <div class="admin-section admin-section--import-result">
                        <h4 class="admin-section__title">K&#7871;t qu&#7843; import g&#7847;n nh&#7845;t</h4>
                        <div class="stats-grid stats-grid--import-summary">
                            <div class="stat-card stat-card--blue">
                                <h3 class="stat-card__label">T&#7893;ng d&ograve;ng s&#7843;n ph&#7849;m</h3>
                                <p class="stat-card__value"><%= bulkImportResult.totalProducts || 0 %></p>
                            </div>
                            <div class="stat-card stat-card--green">
                                <h3 class="stat-card__label">Import th&agrave;nh c&ocirc;ng</h3>
                                <p class="stat-card__value"><%= bulkImportResult.createdCount || 0 %></p>
                            </div>
                            <div class="stat-card stat-card--pink">
                                <h3 class="stat-card__label">B&#7883; l&#7895;i</h3>
                                <p class="stat-card__value"><%= bulkImportResult.failedCount || 0 %></p>
                            </div>
                        </div>

                        <% if (bulkImportResult.createdProducts && bulkImportResult.createdProducts.length > 0) { %>
                            <div class="admin-table-wrapper admin-table-wrapper--spaced">
                                <table class="admin-table">
                                    <thead>
                                        <tr>
                                            <th>Product Key</th>
                                            <th>S&#7843;n ph&#7849;m</th>
                                            <th class="text-center">ID</th>
                                            <th class="text-center">&#7842;nh</th>
                                            <th class="text-center">Bi&#7871;n th&#7875;</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% bulkImportResult.createdProducts.forEach(item => { %>
                                            <tr>
                                                <td><%= item.productKey %></td>
                                                <td><%= item.name %></td>
                                                <td class="text-center"><%= item.productId %></td>
                                                <td class="text-center"><%= item.imageCount %></td>
                                                <td class="text-center"><%= item.variantCount %></td>
                                            </tr>
                                        <% }) %>
                                    </tbody>
                                </table>
                            </div>
                        <% } %>

                        <% if (bulkImportResult.errors && bulkImportResult.errors.length > 0) { %>
                            <div class="admin-table-wrapper">
                                <table class="admin-table">
                                    <thead>
                                        <tr>
                                            <th>Product Key</th>
                                            <th>S&#7843;n ph&#7849;m</th>
                                            <th>L&#7895;i</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% bulkImportResult.errors.forEach(item => { %>
                                            <tr>
                                                <td><%= item.productKey || '-' %></td>
                                                <td><%= item.name || '-' %></td>
                                                <td><%= item.message %></td>
                                            </tr>
                                        <% }) %>
                                    </tbody>
                                </table>
                            </div>
                        <% } %>
                    </div>
                <% } %>
            </div>
        </div>

        <!-- Add Product Form -->
        <div class="admin-section admin-section--collapsible">
            <h3 class="admin-section__title admin-section__title--toggle" data-admin-toggle="section">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="12" y1="5" x2="12" y2="19"/>
                    <line x1="5" y1="12" x2="19" y2="12"/>
                </svg>
                Thêm Sản Phẩm Mới
                <svg class="admin-section__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="6 9 12 15 18 9"/>
                </svg>
            </h3>
            <form id="createProductForm" action="/admin/products" method="POST" enctype="multipart/form-data" class="admin-form admin-section__content">
                <div class="admin-form__row">
                    <div class="admin-form__group">
                        <label class="admin-form__label">Tên sản phẩm <span>*</span></label>
                        <input type="text" name="name" required class="admin-form__input" placeholder="VD: Áo thun nam basic">
                    </div>
                    <div class="admin-form__group">
                        <label class="admin-form__label">Slug</label>
                        <input type="text" name="slug" class="admin-form__input" placeholder="Tự động tạo nếu để trống">
                    </div>
                </div>
                <div class="admin-form__row">
                    <div class="admin-form__group">
                        <label class="admin-form__label">Danh mục <span>*</span></label>
                        <select name="category_id" required class="admin-form__select">
                            <option value="">-- Chọn danh mục --</option>
                            <% if (categories && categories.length > 0) { %>
                                <% categories.forEach(cat => { %>
                                    <option value="<%= cat.id %>"><%= cat.name %></option>
                                <% }) %>
                            <% } %>
                        </select>
                    </div>
                    <div class="admin-form__group">
                        <label class="admin-form__label">Giá (VNĐ) <span>*</span></label>
                        <input type="number" name="price" required class="admin-form__input" placeholder="VD: 350000">
                    </div>
                    <div class="admin-form__group">
                        <label class="admin-form__label">Số lượng</label>
                        <input type="number" name="stock_quantity" value="0" class="admin-form__input" placeholder="VD: 100">
                    </div>
                    <div class="admin-form__group">
                        <label class="admin-form__label">SKU</label>
                        <div class="product-sku-row">
                            <input type="text" name="sku" id="createSkuInput" class="admin-form__input product-sku-row__input" placeholder="VD: ATN-001">
                            <label class="product-sku-row__auto">
                                <input type="checkbox" id="autoSkuCheckbox"> Tự động tạo mã
                            </label>
                        </div>
                    </div>
                </div>
                <div class="admin-form__group">
                    <label class="admin-form__label">Mô tả</label>
                    <textarea name="description" rows="3" class="admin-form__textarea" placeholder="Mô tả chi tiết sản phẩm..."></textarea>
                </div>
                <div class="admin-form__group">
                    <label class="admin-form__label">Hình ảnh</label>
                    <input type="file" name="images" id="createImagesInput" multiple accept="image/*" class="admin-form__input">
                    <div id="createImagesPreview" class="product-upload-preview" hidden></div>
                    <small class="admin-form__hint">Có thể chọn nhiều ảnh cùng lúc</small>
                </div>

                <!-- Biến thể sản phẩm -->
                <input type="hidden" name="variants" id="createVariantsJson" value="[]">
                <div class="admin-form__group product-edit-form__variants">
                    <label class="admin-form__label product-edit-form__variants-title">Biến thể sản phẩm (Size / Màu sắc)</label>
                    <small class="admin-form__hint product-edit-form__variants-hint">Thêm các biến thể nếu sản phẩm có nhiều size hoặc màu sắc</small>
                    <div id="createVariantsList"></div>
                    <button type="button" data-product-action="add-variant" data-product-mode="create" class="product-edit-form__add-variant">
                        + Thêm biến thể
                    </button>
                </div>

                <div class="admin-form__actions">
                    <button type="submit" class="admin-btn admin-btn--primary">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="20 6 9 17 4 12"/>
                        </svg>
                        Thêm Sản Phẩm
                    </button>
                </div>
            </form>
        </div>

        <!-- Products Table -->
        <% if (products && products.length > 0) { %>
            <div class="admin-table-wrapper">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Sản Phẩm</th>
                            <th>Danh Mục</th>
                            <th class="text-right">Giá</th>
                            <th class="text-center">Kho</th>
                            <th class="text-center">Trạng Thái</th>
                            <th class="text-center">Thao Tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% products.forEach(product => { %>
                            <tr>
                                <td><%= product.id %></td>
                                <td>
                                    <div class="product-info">
                                        <div class="product-info__image">
                                            <% if (product.primary_image) { %>
                                                <img src="<%= product.primary_image %>" alt="<%= product.name %>" loading="lazy" decoding="async">
                                            <% } else { %>
                                                <div class="product-info__placeholder">
                                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                                                        <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                                                        <circle cx="8.5" cy="8.5" r="1.5"/>
                                                        <polyline points="21 15 16 10 5 21"/>
                                                    </svg>
                                                </div>
                                            <% } %>
                                        </div>
                                        <div class="product-info__details">
                                            <span class="product-info__name"><%= product.name %></span>
                                            <% if (product.sku) { %>
                                                <span class="product-info__sku">SKU: <%= product.sku %></span>
                                            <% } %>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="product-category"><%= product.category_name || 'Chưa phân loại' %></span>
                                </td>
                                <td class="text-right">
                                    <span class="admin-table__price"><%= product.price.toLocaleString('vi-VN') %>đ</span>
                                </td>
                                <td class="text-center">
                                    <% if (product.stock_quantity > 10) { %>
                                        <span class="stock-badge stock-badge--success"><%= product.stock_quantity %></span>
                                    <% } else if (product.stock_quantity > 0) { %>
                                        <span class="stock-badge stock-badge--warning"><%= product.stock_quantity %></span>
                                    <% } else { %>
                                        <span class="stock-badge stock-badge--danger">Hết</span>
                                    <% } %>
                                </td>
                                <td class="text-center">
                                    <% if (product.is_active !== false) { %>
                                        <span class="admin-table__badge admin-table__badge--delivered">Hiển thị</span>
                                    <% } else { %>
                                        <span class="admin-table__badge admin-table__badge--cancelled">Ẩn</span>
                                    <% } %>
                                </td>
                                <td class="text-center">
                                    <div class="admin-actions-group">
                                        <button
                                            data-product-action="open-image-modal"
                                            data-product-id="<%= product.id %>"
                                            data-product-name="<%= product.name %>"
                                            class="admin-btn admin-btn--image"
                                            title="Quan ly anh"
                                        >
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                                                <circle cx="8.5" cy="8.5" r="1.5"/>
                                                <polyline points="21 15 16 10 5 21"/>
                                            </svg>
                                        </button>
                                        <button
                                            data-product-action="open-edit-modal"
                                            data-product-id="<%= product.id %>"
                                            data-product-name="<%= product.name %>"
                                            data-product-category-id="<%= product.category_id || '' %>"
                                            data-product-price="<%= product.price %>"
                                            data-product-stock="<%= product.stock_quantity %>"
                                            data-product-description="<%= product.description || '' %>"
                                            class="admin-btn admin-btn--edit"
                                            title="Sua"
                                        >
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                                                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                                            </svg>
                                        </button>
                                        <button data-product-action="delete-product" data-product-id="<%= product.id %>" class="admin-btn admin-btn--delete" title="Xóa">
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <polyline points="3 6 5 6 21 6"/>
                                                <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                                            </svg>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
            <%- include('../partials/admin-pagination', { pagination }) %>
        <% } else { %>
            <div class="admin-empty">
                <div class="admin-empty__icon">
                    <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                        <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
                        <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
                        <line x1="12" y1="22.08" x2="12" y2="12"/>
                    </svg>
                </div>
                <h3 class="admin-empty__title">Chưa có sản phẩm nào</h3>
                <p class="admin-empty__text">Thêm sản phẩm đầu tiên để bắt đầu kinh doanh.</p>
            </div>
        <% } %>
    </div>
</div>

<!-- Edit Modal -->
<div id="editModal" class="admin-modal">
    <div class="admin-modal__content admin-modal__content--product-edit">
        <div class="admin-modal__header">
            <h3 class="admin-modal__title">Sửa Sản Phẩm</h3>
            <button class="admin-modal__close" data-product-action="close-edit-modal">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="6" x2="6" y2="18"/>
                    <line x1="6" y1="6" x2="18" y2="18"/>
                </svg>
            </button>
        </div>
        <form id="editForm" class="admin-form product-edit-form">
            <input type="hidden" id="editProductId">
            <div class="product-edit-form__grid">
                <div class="admin-form__group product-edit-form__group--name">
                    <label class="admin-form__label">Tên sản phẩm <span>*</span></label>
                    <input type="text" id="editName" required class="admin-form__input">
                </div>
                <div class="admin-form__group product-edit-form__group--category">
                    <label class="admin-form__label">Danh mục <span>*</span></label>
                    <select id="editCategoryId" required class="admin-form__select">
                        <% if (categories && categories.length > 0) { %>
                            <% categories.forEach(cat => { %>
                                <option value="<%= cat.id %>"><%= cat.name %></option>
                            <% }) %>
                        <% } %>
                    </select>
                </div>
                <div class="admin-form__group product-edit-form__group--price">
                    <label class="admin-form__label">Giá (VNĐ) <span>*</span></label>
                    <input type="number" id="editPrice" required class="admin-form__input">
                </div>
                <div class="admin-form__group product-edit-form__group--stock">
                    <label class="admin-form__label">Số lượng</label>
                    <input type="number" id="editStock" value="0" class="admin-form__input">
                </div>
                <div class="admin-form__group product-edit-form__group--description">
                    <label class="admin-form__label">Mô tả</label>
                    <textarea id="editDescription" rows="4" class="admin-form__textarea"></textarea>
                </div>
            </div>

            <!-- Biến thể sản phẩm (Edit) -->
            <input type="hidden" id="editVariantsJson" value="[]">
            <div class="admin-form__group product-edit-form__variants">
                <label class="admin-form__label product-edit-form__variants-title">Biến thể sản phẩm (Size / Màu sắc)</label>
                <small class="admin-form__hint product-edit-form__variants-hint">Thêm các biến thể nếu sản phẩm có nhiều size hoặc màu sắc</small>
                <div id="editVariantsList"></div>
                <button type="button" data-product-action="add-variant" data-product-mode="edit" class="product-edit-form__add-variant">
                    + Thêm biến thể
                </button>
            </div>

            <div class="admin-modal__buttons">
                <button type="button" data-product-action="close-edit-modal" class="admin-btn admin-btn--ghost">Hủy</button>
                <button type="submit" class="admin-btn admin-btn--primary">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="20 6 9 17 4 12"/>
                    </svg>
                    Lưu Thay Đổi
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Image Management Modal -->
<div id="imageModal" class="admin-modal">
    <div class="admin-modal__content admin-modal__content--product-images">
        <div class="admin-modal__header">
            <h3 class="admin-modal__title">Quản Lý Ảnh: <span id="imageModalProductName"></span></h3>
            <button class="admin-modal__close" data-product-action="close-image-modal">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="6" x2="6" y2="18"/>
                    <line x1="6" y1="6" x2="18" y2="18"/>
                </svg>
            </button>
        </div>
        <input type="hidden" id="imageModalProductId">

        <!-- Current Images -->
        <div class="image-section">
            <h4 class="image-section__title">Ảnh hiện tại</h4>
            <div id="imagesGrid" class="images-grid">
                <p class="images-grid__loading">Đang tải...</p>
            </div>
        </div>

        <!-- Add New Image -->
        <div class="image-section">
            <h4 class="image-section__title">Thêm ảnh mới</h4>
            <form id="addImageForm" enctype="multipart/form-data" class="image-upload">
                <div class="image-upload__file">
                    <input type="file" id="newImageFile" name="images" accept="image/*" multiple class="admin-form__input">
                    <small class="admin-form__hint">Có thể chọn nhiều ảnh cùng lúc</small>
                    <label class="image-upload__checkbox">
                        <input type="checkbox" id="isPrimaryImage"> Đặt làm ảnh chính
                    </label>
                </div>
                <button type="submit" class="admin-btn admin-btn--primary">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                        <polyline points="17 8 12 3 7 8"/>
                        <line x1="12" y1="3" x2="12" y2="15"/>
                    </svg>
                    Tải lên
                </button>
            </form>
            <div class="image-upload__divider">hoặc</div>
            <div class="image-upload__url">
                <input type="text" id="newImageUrl" placeholder="https://example.com/image.jpg" class="admin-form__input">
                <button data-product-action="add-image-url" class="admin-btn admin-btn--primary">Thêm URL</button>
            </div>
        </div>
    </div>
</div>

<!-- Vùng hiển thị toast phản hồi thao tác sản phẩm. -->
<div id="toastContainer"></div>

<!-- Confirm Modal -->
<div id="confirmModal">
    <div class="confirm-modal__content">
        <div class="confirm-modal__icon confirm-modal__icon--danger">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                <line x1="12" y1="9" x2="12" y2="13"/>
                <line x1="12" y1="17" x2="12.01" y2="17"/>
            </svg>
        </div>
        <div class="confirm-modal__text">
            <h3 id="confirmTitle">Xóa Sản Phẩm</h3>
            <p id="confirmMessage">Bạn có chắc muốn xóa sản phẩm này? Hành động không thể hoàn tác.</p>
        </div>
        <div id="confirmTypingGroup" class="confirm-modal__typing" hidden>
            <label id="confirmTypingLabel" for="confirmTypingInput" class="confirm-modal__typing-label">Nhập "Xóa tất cả" để xác nhận</label>
            <input
                id="confirmTypingInput"
                type="text"
                class="confirm-modal__typing-input"
                autocomplete="off"
                spellcheck="false"
                placeholder="Xóa tất cả"
            >
            <small id="confirmTypingHint" class="confirm-modal__typing-hint"></small>
        </div>
        <div class="confirm-modal__buttons">
            <button id="confirmNo" class="admin-btn admin-btn--ghost">Hủy</button>
            <button id="confirmYes" class="admin-btn admin-btn--danger">Xóa</button>
        </div>
    </div>
</div>



<script src="/js/admin/products.js?v=otp-modal-20260513"></script>

<%- include('../partials/admin-footer') %>
