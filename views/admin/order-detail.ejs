<%- include('../partials/admin-header', { currentPage: 'orders' }) %>

<div class="admin-page">
    <div class="container">
        <!-- Back Button -->
        <a href="/admin/orders" class="back-link">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="15 18 9 12 15 6"/>
            </svg>
            Quay lại danh sách
        </a>

        <% if (order) { %>

        <!-- Order Header -->
        <div class="order-detail-header">
            <div class="order-detail-header__left">
                <h1>Đơn hàng #<%= order.order_code %></h1>
                <p>Ngày đặt: <%= new Date(order.created_at).toLocaleString('vi-VN') %></p>
            </div>
            <div class="order-detail-header__right">
                <%
                    let statusClass = '';
                    let statusText = '';
                    switch(order.status) {
                        case 'pending': statusClass = 'admin-table__badge--pending'; statusText = 'Chờ xử lý'; break;
                        case 'confirmed': statusClass = 'admin-table__badge--processing'; statusText = 'Đã xác nhận'; break;
                        case 'shipping': statusClass = 'admin-table__badge--shipped'; statusText = 'Đang giao'; break;
                        case 'delivered': statusClass = 'admin-table__badge--delivered'; statusText = 'Đã giao'; break;
                        case 'cancelled': statusClass = 'admin-table__badge--cancelled'; statusText = 'Đã hủy'; break;
                        default: statusText = order.status;
                    }
                %>
                <span class="admin-table__badge <%= statusClass %>" style="font-size: 14px; padding: 8px 16px;"><%= statusText %></span>
            </div>
        </div>

        <!-- Info Grid -->
        <div class="order-detail-grid">
            <!-- Customer Info -->
            <div class="admin-section">
                <h3 class="admin-section__title">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                        <circle cx="9" cy="7" r="4"/>
                    </svg>
                    Thông tin khách hàng
                </h3>
                <div class="info-list">
                    <div class="info-item">
                        <span class="info-item__label">Họ tên</span>
                        <span class="info-item__value"><%= order.user_name || 'N/A' %></span>
                    </div>
                    <div class="info-item">
                        <span class="info-item__label">Email</span>
                        <span class="info-item__value"><%= order.user_email || 'N/A' %></span>
                    </div>
                </div>
            </div>

            <!-- Shipping Info -->
            <div class="admin-section">
                <h3 class="admin-section__title">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="1" y="3" width="15" height="13"/>
                        <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/>
                        <circle cx="5.5" cy="18.5" r="2.5"/>
                        <circle cx="18.5" cy="18.5" r="2.5"/>
                    </svg>
                    Địa chỉ giao hàng
                </h3>
                <div class="info-list">
                    <div class="info-item">
                        <span class="info-item__label">Người nhận</span>
                        <span class="info-item__value"><%= order.shipping_name || order.recipient_name || 'N/A' %></span>
                    </div>
                    <div class="info-item">
                        <span class="info-item__label">SĐT</span>
                        <span class="info-item__value"><%= order.shipping_phone || order.recipient_phone || 'N/A' %></span>
                    </div>
                    <div class="info-item">
                        <span class="info-item__label">Địa chỉ</span>
                        <span class="info-item__value">
                            <%= order.address_line || '' %><% if (order.ward) { %>, <%= order.ward %><% } %><% if (order.district) { %>, <%= order.district %><% } %><% if (order.city) { %>, <%= order.city %><% } %>
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Order Items -->
        <div class="admin-section" style="margin-top: 24px;">
            <h3 class="admin-section__title">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
                    <line x1="3" y1="6" x2="21" y2="6"/>
                    <path d="M16 10a4 4 0 0 1-8 0"/>
                </svg>
                Sản phẩm (<%= order.items ? order.items.length : 0 %>)
            </h3>
            <% if (order.items && order.items.length > 0) { %>
                <div class="admin-table-wrapper">
                    <table class="admin-table">
                        <thead>
                            <tr>
                                <th>Sản phẩm</th>
                                <th class="text-right">Đơn giá</th>
                                <th class="text-center">SL</th>
                                <th class="text-right">Thành tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% order.items.forEach(item => { %>
                                <tr>
                                    <td>
                                        <div class="item-info">
                                            <% if (item.product_image) { %>
                                                <img src="<%= item.product_image %>" alt="<%= item.product_name %>" class="item-info__img">
                                            <% } %>
                                            <div>
                                                <strong><%= item.product_name || 'Sản phẩm #' + item.product_id %></strong>
                                                <% if (item.sku) { %><br><small style="color: var(--admin-text-muted);">SKU: <%= item.sku %></small><% } %>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-right"><%= (item.price || 0).toLocaleString('vi-VN') %>đ</td>
                                    <td class="text-center"><%= item.quantity %></td>
                                    <td class="text-right"><strong><%= ((item.price || 0) * (item.quantity || 1)).toLocaleString('vi-VN') %>đ</strong></td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            <% } else { %>
                <p style="color: var(--admin-text-muted);">Không có sản phẩm</p>
            <% } %>
        </div>

        <!-- Order Summary + Payment + Status Update -->
        <div class="order-detail-grid" style="margin-top: 24px;">
            <!-- Payment & Total -->
            <div class="admin-section">
                <h3 class="admin-section__title">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="12" y1="1" x2="12" y2="23"/>
                        <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
                    </svg>
                    Thanh toán
                </h3>
                <div class="summary-list">
                    <div class="summary-item">
                        <span>Tạm tính</span>
                        <span><%= (order.total_amount || 0).toLocaleString('vi-VN') %>đ</span>
                    </div>
                    <% if (order.shipping_fee) { %>
                    <div class="summary-item">
                        <span>Phí vận chuyển</span>
                        <span><%= (order.shipping_fee || 0).toLocaleString('vi-VN') %>đ</span>
                    </div>
                    <% } %>
                    <% if (order.discount_amount > 0) { %>
                    <div class="summary-item" style="color: var(--admin-success);">
                        <span>Giảm giá</span>
                        <span>-<%= (order.discount_amount || 0).toLocaleString('vi-VN') %>đ</span>
                    </div>
                    <% } %>
                    <div class="summary-item summary-item--total">
                        <span>Tổng thanh toán</span>
                        <span><%= (order.final_amount || order.total_amount || 0).toLocaleString('vi-VN') %>đ</span>
                    </div>
                    <div class="summary-item">
                        <span>Phương thức</span>
                        <span>
                            <% if (order.payment_method === 'cod') { %>Thanh toán khi nhận hàng
                            <% } else if (order.payment_method === 'bank_transfer') { %>Chuyển khoản
                            <% } else { %><%= order.payment_method || 'N/A' %><% } %>
                        </span>
                    </div>
                    <div class="summary-item">
                        <span>Trạng thái TT</span>
                        <span>
                            <% if (order.payment_status === 'paid') { %>
                                <span class="admin-table__badge admin-table__badge--delivered">Đã thanh toán</span>
                            <% } else { %>
                                <span class="admin-table__badge admin-table__badge--pending">Chưa thanh toán</span>
                            <% } %>
                        </span>
                    </div>
                </div>
            </div>

            <!-- Update Status -->
            <div class="admin-section">
                <h3 class="admin-section__title">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="23 4 23 10 17 10"/>
                        <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/>
                    </svg>
                    Cập nhật trạng thái
                </h3>
                <div class="status-update">
                    <select id="statusSelect" class="admin-form__select order-status-select order-status-select--<%= order.status %>">
                        <option value="pending" <%= order.status === 'pending' ? 'selected' : '' %>>Chờ xử lý</option>
                        <option value="confirmed" <%= order.status === 'confirmed' ? 'selected' : '' %>>Đã xác nhận</option>
                        <option value="shipping" <%= order.status === 'shipping' ? 'selected' : '' %>>Đang giao</option>
                        <option value="delivered" <%= order.status === 'delivered' ? 'selected' : '' %>>Đã giao</option>
                        <option value="cancelled" <%= order.status === 'cancelled' ? 'selected' : '' %>>Đã hủy</option>
                    </select>
                    <button onclick="updateStatus()" class="admin-btn admin-btn--primary" style="margin-top: 12px; width: 100%;">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="20 6 9 17 4 12"/>
                        </svg>
                        Cập nhật
                    </button>
                </div>

                <% if (order.notes) { %>
                <div style="margin-top: 20px;">
                    <h4 style="font-size: 13px; color: var(--admin-text-secondary); margin: 0 0 8px 0;">Ghi chú</h4>
                    <p style="font-size: 14px; color: var(--admin-text-primary); margin: 0; padding: 12px; background: var(--admin-bg); border-radius: 8px;"><%= order.notes %></p>
                </div>
                <% } %>
            </div>
        </div>

        <% } else { %>
        <div class="admin-empty" style="margin-top: 32px;">
            <div class="admin-empty__icon">📦</div>
            <h3 class="admin-empty__title">Không tìm thấy đơn hàng</h3>
            <p class="admin-empty__text">Đơn hàng này không tồn tại hoặc đã bị xóa.</p>
            <a href="/admin/orders" class="admin-btn admin-btn--primary" style="margin-top: 16px;">Quay lại</a>
        </div>
        <% } %>
    </div>
</div>

<!-- Toast Container -->
<div id="toastContainer"></div>

<style>
.back-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--admin-text-secondary);
    text-decoration: none;
    font-size: 14px;
    margin-bottom: 20px;
    transition: color 0.2s;
}
.back-link:hover { color: var(--admin-accent); }

.order-detail-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 28px;
    flex-wrap: wrap;
    gap: 12px;
}
.order-detail-header__left h1 {
    font-size: 24px;
    font-weight: 700;
    color: var(--admin-text-primary);
    margin: 0 0 4px 0;
}
.order-detail-header__left p {
    font-size: 14px;
    color: var(--admin-text-secondary);
    margin: 0;
}

.order-detail-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
}

.info-list { display: flex; flex-direction: column; gap: 14px; }
.info-item {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 12px;
}
.info-item__label {
    font-size: 13px;
    color: var(--admin-text-secondary);
    flex-shrink: 0;
    min-width: 80px;
}
.info-item__value {
    font-size: 14px;
    color: var(--admin-text-primary);
    font-weight: 500;
    text-align: right;
    word-break: break-word;
}

.item-info {
    display: flex;
    align-items: center;
    gap: 12px;
}
.item-info__img {
    width: 48px;
    height: 48px;
    border-radius: 8px;
    object-fit: cover;
    flex-shrink: 0;
}

.summary-list { display: flex; flex-direction: column; gap: 12px; }
.summary-item {
    display: flex;
    justify-content: space-between;
    font-size: 14px;
    color: var(--admin-text-secondary);
}
.summary-item--total {
    padding-top: 12px;
    border-top: 2px solid var(--admin-border);
    font-weight: 700;
    font-size: 16px;
    color: var(--admin-danger);
}

.status-update select {
    width: 100%;
    padding: 10px 14px;
    font-size: 14px;
}

/* Order Status Select */
.order-status-select { border: 1px solid var(--admin-border); border-radius: 8px; background: var(--admin-card-bg); }
.order-status-select--pending { border-color: #f59e0b; color: #b45309; }
.order-status-select--confirmed { border-color: #3b82f6; color: #1d4ed8; }
.order-status-select--shipping { border-color: #8b5cf6; color: #6d28d9; }
.order-status-select--delivered { border-color: #10b981; color: #047857; }
.order-status-select--cancelled { border-color: #ef4444; color: #b91c1c; }

@media (max-width: 768px) {
    .order-detail-grid { grid-template-columns: 1fr; }
    .order-detail-header { flex-direction: column; align-items: flex-start; }
    .order-detail-header__left h1 { font-size: 18px; }
    .info-item { flex-direction: column; gap: 4px; }
    .info-item__value { text-align: left; }
}
</style>

<script>
async function updateStatus() {
    const status = document.getElementById('statusSelect').value;
    try {
        const response = await fetch('/admin/orders/<%= order ? order.id : '' %>/status', {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ status })
        });
        if (response.ok) {
            showToast('Cập nhật trạng thái thành công!');
            setTimeout(() => location.reload(), 1000);
        } else {
            showToast('Lỗi cập nhật trạng thái', 'error');
        }
    } catch (error) {
        showToast('Lỗi: ' + error.message, 'error');
    }
}

function showToast(message, type = 'success') {
    const container = document.getElementById('toastContainer');
    if (!container) return;
    const bgColor = type === 'success' ? 'linear-gradient(135deg, #4caf50, #45a049)' :
                    type === 'error' ? 'linear-gradient(135deg, #f44336, #d32f2f)' :
                    'linear-gradient(135deg, #2196f3, #1976d2)';
    const icon = type === 'success' ? '✅' : type === 'error' ? '❌' : 'ℹ️';
    const toast = document.createElement('div');
    toast.innerHTML = `
        <div style="display: flex; align-items: center; gap: 12px; background: ${bgColor}; color: white; padding: 16px 24px; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.25); margin-bottom: 10px; min-width: 280px; animation: slideInRight 0.3s ease;">
            <span style="font-size: 20px;">${icon}</span>
            <span style="font-size: 14px; font-weight: 500;">${message}</span>
        </div>
    `;
    container.appendChild(toast);
    setTimeout(() => toast.remove(), 3000);
}
</script>

<%- include('../partials/admin-footer') %>
