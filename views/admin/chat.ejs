<%- include('../partials/admin-header', { currentPage: 'chat', pageStyles: ['/css/admin/chat.css'] }) %>



<div class="admin-page admin-page--chat">
    <h1 class="admin-page__title">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
        </svg>
        Quản Lý Trò Chuyện
        <span
            id="adminChatUnreadCountBadge"
            class="admin-chat-page__badge"
            <%= unreadCount > 0 ? "" : "hidden" %>
        ><%= unreadCount %> chưa đọc</span>
    </h1>

    <div class="admin-chat-layout">
        <section class="admin-chat-list">
            <div class="admin-chat-list__header">
                <div>
                    <h3>Hộp thư khách hàng</h3>
                    <p id="chatListSummary"><%= total %> cuộc trò chuyện</p>
                </div>
                <div class="admin-chat-list__search">
                    <input
                        type="search"
                        id="adminChatSearchInput"
                        class="admin-form__input"
                        placeholder="Tìm theo tên, email, nội dung..."
                        
                    >
                </div>
            </div>
            <div class="admin-chat-list__items" id="chatListItems"></div>
        </section>

        <section class="admin-chat-detail">
            <div class="admin-chat-detail__empty" id="chatDetailEmpty">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#cbd5e1" stroke-width="1.5">
                    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                </svg>
                <p>Chọn một cuộc trò chuyện để xem chi tiết.</p>
            </div>

            <div class="admin-chat-detail__content" id="chatDetailContent" hidden>
                <div class="admin-chat-detail__header">
                    <div class="admin-chat-detail__user">
                        <div class="admin-chat-detail__title-row">
                            <strong id="chatUserName">Khách</strong>
                            <span class="admin-chat-detail__chip" id="chatConversationStatus">Đang mở</span>
                            <span class="admin-chat-detail__chip admin-chat-detail__chip--mode" id="chatConversationMode">AI tự động</span>
                        </div>
                        <span class="admin-chat-detail__email" id="chatUserEmail"></span>
                    </div>
                    <div class="admin-chat-detail__actions">
                        <button type="button" id="chatModeBtn" class="admin-btn admin-btn--ghost" >
                            Tiếp quản
                        </button>
                        <button type="button" id="chatStatusBtn" class="admin-btn admin-btn--danger" >
                            Đóng
                        </button>
                    </div>
                </div>

                <div class="admin-chat-detail__messages" id="adminChatMessages"></div>

                <div class="admin-chat-detail__input">
                    <form id="adminReplyForm" >
                        <input
                            type="text"
                            id="adminReplyInput"
                            placeholder="Nhập tin nhắn trả lời..."
                            autocomplete="off"
                            maxlength="1000"
                        >
                        <button type="submit" class="admin-btn admin-btn--primary" id="adminReplySendBtn">Gửi</button>
                    </form>
                    <p class="admin-chat-detail__hint" id="adminReplyHint">
                        Gửi tin nhắn từ đây sẽ tự chuyển cuộc trò chuyện sang chế độ admin tiếp quản.
                    </p>
                </div>
            </div>
        </section>
    </div>
</div>

<script type="application/json" id="adminChatBootstrap"><%- JSON.stringify({
    conversations,
    unreadCount,
    total
}).replace(/</g, '\u003c') %></script>



<script src="/js/admin/chat.js"></script>

<%- include('../partials/admin-footer', { hideAdminFooter: true }) %>
