<%- include('../partials/admin-header', { currentPage: 'orders', activeGroup, pageStyles: ['/css/admin/orders.css'] }) %>

<%
    const currentActiveGroup = typeof activeGroup !== 'undefined' ? activeGroup : 'all';
    const currentOrderGroups = Array.isArray(typeof orderGroups !== 'undefined' ? orderGroups : null) ? orderGroups : [];
    const currentOrderGroupCounts = typeof orderGroupCounts !== 'undefined' && orderGroupCounts ? orderGroupCounts : {};
    const activeGroupMeta = currentOrderGroups.find((group) => group.key === currentActiveGroup) || { label: 'Tất cả' };
    const orderStatusLabels = {
        pending_payment: 'Chờ thanh toán',
        pending: 'Chờ xác nhận',
        confirmed: 'Đã xác nhận',
        processing: 'Đang xử lý',
        shipping: 'Đang giao',
        delivered: 'Đã giao',
        completed: 'Đã hoàn thành',
        cancelled: 'Đã hủy'
    };
%>

<div class="admin-page">
    <div class="container">
        <div class="admin-page-header">
            <div class="admin-page-header__left">
                <h1>Quản lý đơn hàng</h1>
                <p><%= orders ? orders.length : 0 %> mục trong nhóm <%= activeGroupMeta.label %></p>
            </div>
        </div>

        <div class="admin-section admin-section--tabs">
            <nav class="order-management-menu" aria-label="Nhóm quản lý đơn hàng">
                <% currentOrderGroups.forEach((group) => { %>
                    <a class="order-management-menu__link <%= currentActiveGroup === group.key ? 'active' : '' %>" href="<%= group.href %>">
                        <span><%= group.label %></span>
                        <span class="order-management-menu__count"><%= currentOrderGroupCounts[group.key] || 0 %></span>
                    </a>
                <% }) %>
            </nav>
        </div>

        <div class="admin-toolbar">
            <div class="admin-toolbar__info">
                <p class="admin-toolbar__title">Tìm đơn hàng</p>
                <% if (searchQuery) { %>
                    <p class="admin-toolbar__text">Đang lọc với từ khóa: "<strong><%= searchQuery %></strong>"</p>
                <% } %>
            </div>
            <form action="/admin/orders" method="GET" class="admin-search-form">
                <% if (currentActiveGroup !== 'all') { %>
                    <input type="hidden" name="group" value="<%= currentActiveGroup %>">
                <% } %>
                <input
                    type="search"
                    name="search"
                    value="<%= searchQuery || '' %>"
                    class="admin-form__input admin-search-form__input"
                    placeholder="VD: ORD..., tên khách, email..."
                >
                <div class="admin-search-form__actions">
                    <button type="submit" class="admin-btn admin-btn--primary">Tìm kiếm</button>
                    <% if (searchQuery) { %>
                        <a href="<%= currentActiveGroup === 'all' ? '/admin/orders' : '/admin/orders?group=' + currentActiveGroup %>" class="admin-btn admin-btn--ghost">Xóa lọc</a>
                    <% } %>
                </div>
            </form>
        </div>

        <% if (orders && orders.length > 0) { %>
            <div class="admin-table-wrapper">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>Mã đơn</th>
                            <th>Khách hàng</th>
                            <th>Sản phẩm</th>
                            <th class="text-right">Tổng tiền</th>
                            <th class="text-center">Thanh toán</th>
                            <th class="text-center">Trạng thái</th>
                            <th class="text-center">Ngày đặt</th>
                            <th class="text-center">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% orders.forEach(order => {
                            const isPaymentSettled = order.payment_status === 'paid' || ['delivered', 'completed'].includes(order.status);
                            const paymentStatusText = isPaymentSettled ? 'Đã thanh toán' : (order.payment_method === 'cod' ? 'COD' : 'Chưa thanh toán');
                            const paymentStatusClass = isPaymentSettled ? 'admin-table__badge--delivered' : (order.payment_method === 'cod' ? 'admin-table__badge--processing' : 'admin-table__badge--pending');
                            const canShowCountdown = order.status === 'pending_payment' && order.payment_status !== 'paid' && ['vnpay', 'momo'].includes(String(order.payment_method || '').toLowerCase()) && order.payment_expires_at;
                        %>
                            <tr data-status="<%= order.status %>">
                                <td>
                                    <a href="/admin/orders/<%= order.id %>" class="admin-table__link">
                                        <strong><%= order.order_code %></strong>
                                    </a>
                                </td>
                                <td>
                                    <div class="order-customer">
                                        <span class="order-customer__name"><%= order.user_name || order.recipient_name || 'N/A' %></span>
                                        <% if (order.recipient_phone) { %>
                                            <span class="order-customer__phone"><%= privacy.maskPhone(order.recipient_phone) %></span>
                                        <% } else if (order.user_email) { %>
                                            <span class="order-customer__phone"><%= privacy.maskEmail(order.user_email) %></span>
                                        <% } %>
                                    </div>
                                </td>
                                <td>
                                    <div class="order-products">
                                        <% (order.items || []).forEach((item) => { %>
                                            <% if (item.product_slug) { %>
                                                <a class="order-products__link" href="/products/<%= item.product_slug %>" target="_blank" rel="noopener"><%= item.product_name %></a>
                                            <% } else { %>
                                                <span class="order-products__link"><%= item.product_name %></span>
                                            <% } %>
                                        <% }) %>
                                        <% if ((order.item_count || 0) > (order.items || []).length) { %>
                                            <span class="order-products__more">+<%= order.item_count - (order.items || []).length %> sản phẩm khác</span>
                                        <% } %>
                                    </div>
                                </td>
                                <td class="text-right">
                                    <span class="admin-table__price"><%= (order.final_amount || order.total_amount || 0).toLocaleString('vi-VN') %>đ</span>
                                </td>
                                <td class="text-center">
                                    <span class="admin-table__badge <%= paymentStatusClass %>"><%= paymentStatusText %></span>
                                </td>
                                <td class="text-center">
                                    <select data-order-id="<%= order.id %>" class="order-status-select order-status-select--<%= order.status %>">
                                        <% if (order.status === 'pending_payment') { %>
                                            <option value="pending_payment" selected>Chờ thanh toán</option>
                                        <% } %>
                                        <option value="pending" <%= order.status === 'pending' ? 'selected' : '' %>>Chờ xác nhận</option>
                                        <option value="confirmed" <%= order.status === 'confirmed' ? 'selected' : '' %>>Đã xác nhận</option>
                                        <option value="processing" <%= order.status === 'processing' ? 'selected' : '' %>>Đang xử lý</option>
                                        <option value="shipping" <%= order.status === 'shipping' ? 'selected' : '' %>>Đang giao</option>
                                        <option value="delivered" <%= order.status === 'delivered' ? 'selected' : '' %>>Đã giao</option>
                                        <% if (order.status === 'completed') { %>
                                            <option value="completed" selected disabled>Đã hoàn thành</option>
                                        <% } %>
                                        <option value="cancelled" <%= order.status === 'cancelled' ? 'selected' : '' %>>Đã hủy</option>
                                    </select>
                                    <% if (canShowCountdown) { %>
                                        <span class="payment-countdown" data-payment-countdown data-expires-at="<%= new Date(order.payment_expires_at).toISOString() %>"></span>
                                    <% } %>
                                </td>
                                <td class="text-center">
                                    <span class="order-date"><%= new Date(order.created_at).toLocaleDateString('vi-VN') %></span>
                                </td>
                                <td class="text-center">
                                    <div class="admin-actions-group">
                                        <a href="/admin/orders/<%= order.id %>" class="admin-btn admin-btn--edit" title="Xem chi tiết">
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                                <circle cx="12" cy="12" r="3"/>
                                            </svg>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } else { %>
            <div class="admin-empty">
                <h3 class="admin-empty__title">Không có mục nào trong nhóm này</h3>
                <p class="admin-empty__text">Khi đơn hàng chuyển sang trạng thái phù hợp, danh sách sẽ được cập nhật tại đây.</p>
            </div>
        <% } %>
    </div>
</div>

<div id="toastContainer"></div>

<script src="/js/admin/orders.js"></script>

<%- include('../partials/admin-footer') %>
