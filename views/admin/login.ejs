<%# Trang đăng nhập admin dùng theme storefront nhưng không gắn header, nav hoặc footer mua sắm. %>
<!DOCTYPE html>
<html lang="vi">
<%
    const loginSettings = typeof storefrontSettings !== 'undefined' && storefrontSettings ? storefrontSettings : {};
    const loginSiteName = loginSettings.site_name || 'WIND OF FALL';
    const loginLogoUrl = loginSettings.admin_logo_url || loginSettings.logo_url || '/favicon.png';
    const loginFaviconUrl = loginSettings.favicon_url || '/favicon.png';
%>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đăng nhập quản trị | <%= loginSiteName %></title>
    <link rel="icon" type="image/png" href="<%= loginFaviconUrl %>">
    <link rel="shortcut icon" href="<%= loginFaviconUrl %>">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/admin/login.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body class="admin-login-body" data-user-authenticated="false">
    <% const adminLoginRedirect = typeof redirect !== 'undefined' ? redirect : '/admin/dashboard'; %>

    <main class="admin-login-page auth-page auth-page--admin">
        <div class="admin-login-topbar" aria-label="Thanh truy cập quản trị">
            <a href="/" class="admin-login-brand" aria-label="<%= loginSiteName %>">
                <img src="<%= loginLogoUrl %>" alt="<%= loginSiteName %>" class="admin-login-brand__mark">
                <span class="admin-login-brand__text">
                    <strong><%= loginSiteName %></strong>
                    <small>Không gian quản trị</small>
                </span>
            </a>

            <a href="/" class="admin-login-storefront-link">Về cửa hàng</a>
        </div>

        <section class="admin-login-shell auth-shell" aria-labelledby="admin-login-title">
            <div class="admin-login-visual auth-visual">
                <p class="auth-visual__eyebrow">Khu vực quản trị</p>
                <h1 id="admin-login-title" class="auth-visual__title">Đăng nhập để vận hành cửa hàng.</h1>
                <p class="auth-visual__copy">Không gian riêng cho đội ngũ quản trị sản phẩm, đơn hàng, nội dung và chăm sóc khách hàng.</p>

                <ul class="auth-visual__highlights">
                    <li>Chỉ tài khoản admin đã được cấp quyền mới hợp lệ</li>
                    <li>Google OAuth quay về callback riêng của admin</li>
                    <li>Sau xác thực sẽ chuyển thẳng vào bảng điều khiển</li>
                </ul>
            </div>

            <div class="admin-login-card auth-container">
                <h2>Đăng nhập Admin</h2>
                <p class="auth-container__copy">Dùng email, mật khẩu hoặc tài khoản Google đã được cấp quyền admin.</p>
                <p class ="form-group"> </p>

                <% if (error) { %>
                    <div class="alert alert-error"><%= error %></div>
                <% } %>

                <form action="/admin/login" method="POST" class="auth-form">
                    <% if (adminLoginRedirect) { %>
                        <input type="hidden" name="redirect" value="<%= adminLoginRedirect %>">
                    <% } %>

                    <div class="form-group">
                        <label for="admin-email">Email quản trị</label>
                        <input type="email" id="admin-email" name="email" value="<%= email %>" required placeholder="Email quản trị" autocomplete="email">
                    </div>

                    <div class="form-group">
                        <label for="admin-password">Mật khẩu</label>
                        <div class="password-field">
                            <input type="password" id="admin-password" name="password" required placeholder="Mật khẩu" autocomplete="current-password">
                            <button type="button" class="password-toggle" data-password-target="admin-password" aria-label="Hiển thị mật khẩu" aria-pressed="false">
                                <img class="eye-open" src="https://res.cloudinary.com/drs7xrtxo/image/upload/v1777038652/istockphoto-1481681927-612x612_n4gfaw.jpg" alt="" aria-hidden="true">
                                <img class="eye-closed" src="https://res.cloudinary.com/drs7xrtxo/image/upload/v1777038652/istockphoto-1481681933-612x612_pywojy.jpg" alt="" aria-hidden="true" hidden>
                            </button>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary btn-block">Đăng nhập</button>
                </form>

                <div class="auth-divider">
                    <span>hoặc</span>
                </div>

                <a href="/admin/google<%= adminLoginRedirect ? '?redirect=' + encodeURIComponent(adminLoginRedirect) : '' %>" class="auth-google-btn">
                    <img src="https://developers.google.com/identity/images/g-logo.png" alt="Google" width="18" height="18">
                    <span>Tiếp tục với Google</span>
                </a>

                <div class="admin-login-card__note">
                    <strong>Lưu ý:</strong> tài khoản người dùng hoặc Google chưa có quyền admin sẽ bị từ chối.
                </div>
            </div>
        </section>
    </main>

    <script src="/js/login.js"></script>
</body>
</html>
