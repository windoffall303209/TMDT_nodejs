<%- include('../partials/admin-header', { currentPage: 'banners', pageStyles: ['/css/admin/banners.css'] }) %>

<div class="admin-page">
    <div class="container">
        <!-- Page Header -->
        <div class="admin-page-header">
            <div class="admin-page-header__left">
                <h1>Quản Lý Banner</h1>
                <p><%= banners ? banners.length : 0 %> banner</p>
            </div>
        </div>

        <!-- Add Banner Form -->
        <div class="admin-section admin-section--collapsible">
            <h3 class="admin-section__title admin-section__title--toggle" data-admin-toggle="section">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="12" y1="5" x2="12" y2="19"/>
                    <line x1="5" y1="12" x2="19" y2="12"/>
                </svg>
                Thêm Banner Mới
                <svg class="admin-section__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="6 9 12 15 18 9"/>
                </svg>
            </h3>
            <form action="/admin/banners" method="POST" enctype="multipart/form-data" class="admin-form admin-section__content">
                <div class="admin-form__row">
                    <div class="admin-form__group">
                        <label class="admin-form__label">Tiêu đề <span>*</span></label>
                        <input type="text" name="title" required class="admin-form__input" placeholder="VD: BST Mùa Đông 2024">
                    </div>
                    <div class="admin-form__group">
                        <label class="admin-form__label">Phụ đề</label>
                        <input type="text" name="subtitle" class="admin-form__input" placeholder="VD: Giảm giá lên đến 50%">
                    </div>
                </div>
                <div class="admin-form__row">
                    <div class="admin-form__group">
                        <label class="admin-form__label">Link URL</label>
                        <input type="text" name="link_url" class="admin-form__input" placeholder="VD: /products?sale=true">
                    </div>
                    <div class="admin-form__group">
                        <label class="admin-form__label">Hình ảnh</label>
                        <input type="file" name="image" accept="image/*" class="admin-form__input">
                    </div>
                </div>
                <div class="admin-form__actions">
                    <button type="submit" class="admin-btn admin-btn--primary">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="20 6 9 17 4 12"/>
                        </svg>
                        Thêm Banner
                    </button>
                </div>
            </form>
        </div>

        <!-- Banners Grid -->
        <% if (banners && banners.length > 0) { %>
            <p style="margin-bottom:12px; color:#888; font-size:13px;">💡 Kéo thả để sắp xếp thứ tự banner. Thứ tự sẽ tự động lưu.</p>
            <div class="banners-grid" id="bannersGrid">
                <% banners.forEach((banner, index) => { %>
                    <div class="banner-card<%= banner.is_active === 0 || banner.is_active === false ? ' banner-card--hidden' : '' %>" data-banner-id="<%= banner.id %>" draggable="true">
                        <div class="banner-card__image">
                            <% if (banner.image_url) { %>
                                <img src="<%= banner.image_url %>" alt="<%= banner.title %>">
                            <% } else { %>
                                <div class="banner-card__placeholder">
                                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                                        <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                                        <circle cx="8.5" cy="8.5" r="1.5"/>
                                        <polyline points="21 15 16 10 5 21"/>
                                    </svg>
                                </div>
                            <% } %>
                            <div class="banner-card__order">#<%= index + 1 %></div>
                            <!-- Status badge -->
                            <div class="banner-card__status-badge" style="position:absolute; top:8px; left:8px; padding:3px 10px; border-radius:20px; font-size:11px; font-weight:700; letter-spacing:.3px; <%= (banner.is_active === 0 || banner.is_active === false) ? 'background:rgba(244,67,54,.9); color:#fff;' : 'background:rgba(76,175,80,.9); color:#fff;' %>">
                                <%= (banner.is_active === 0 || banner.is_active === false) ? 'Đang ẩn' : 'Đang hiện' %>
                            </div>
                            <div class="banner-card__overlay">
                                <% if (banner.link_url) { %>
                                    <a href="<%= banner.link_url %>" target="_blank" class="banner-card__btn" title="Xem link">
                                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                                            <polyline points="15 3 21 3 21 9"/>
                                            <line x1="10" y1="14" x2="21" y2="3"/>
                                        </svg>
                                    </a>
                                <% } %>
                                <!-- Toggle active button -->
                                <button data-banner-action="toggle" data-banner-id="<%= banner.id %>" class="banner-card__btn" title="<%= (banner.is_active === 0 || banner.is_active === false) ? 'Hiện banner' : 'Ẩn banner' %>">
                                    <% if (banner.is_active === 0 || banner.is_active === false) { %>
                                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/>
                                            <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/>
                                            <line x1="1" y1="1" x2="23" y2="23"/>
                                        </svg>
                                    <% } else { %>
                                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                            <circle cx="12" cy="12" r="3"/>
                                        </svg>
                                    <% } %>
                                </button>
                                <!-- Edit button -->
                                <button data-banner-action="edit" data-banner-id="<%= banner.id %>" class="banner-card__btn" title="Sửa banner">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                                    </svg>
                                </button>
                                <button data-banner-action="delete" data-banner-id="<%= banner.id %>" class="banner-card__btn banner-card__btn--delete" title="Xóa banner">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <polyline points="3 6 5 6 21 6"/>
                                        <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                                    </svg>
                                </button>
                            </div>
                        </div>
                        <div class="banner-card__content">
                            <h4 class="banner-card__title"><%= banner.title || 'Chưa có thông tin' %></h4>
                            <p class="banner-card__subtitle"><%= banner.subtitle || 'Chưa có thông tin' %></p>
                            <span class="banner-card__link"><%= banner.link_url || 'Chưa có thông tin' %></span>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <div class="admin-empty">
                <div class="admin-empty__icon">
                    <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                        <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                        <circle cx="8.5" cy="8.5" r="1.5"/>
                        <polyline points="21 15 16 10 5 21"/>
                    </svg>
                </div>
                <h3 class="admin-empty__title">Chưa có banner nào</h3>
                <p class="admin-empty__text">Thêm banner để hiển thị trên trang chủ.</p>
            </div>
        <% } %>
    </div>
</div>

<!-- Toast Container -->
<div id="toastContainer"></div>

<!-- Confirm Modal -->
<div id="confirmModal">
    <div class="confirm-modal__content">
        <div class="confirm-modal__icon confirm-modal__icon--danger">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                <line x1="12" y1="9" x2="12" y2="13"/>
                <line x1="12" y1="17" x2="12.01" y2="17"/>
            </svg>
        </div>
        <div class="confirm-modal__text">
            <h3 id="confirmTitle">Xóa Banner</h3>
            <p id="confirmMessage">Bạn có chắc muốn xóa banner này? Hành động không thể hoàn tác.</p>
        </div>
        <div class="confirm-modal__buttons">
            <button id="confirmNo" class="admin-btn admin-btn--ghost">Hủy</button>
            <button id="confirmYes" class="admin-btn admin-btn--danger">Xóa</button>
        </div>
    </div>
</div>

<!-- Edit Banner Modal -->
<div id="editBannerModal" class="admin-modal">
    <div class="admin-modal__content" style="max-width:540px;">
        <div class="admin-modal__header">
            <h3 class="admin-modal__title">Sửa Banner</h3>
            <button type="button" class="admin-modal__close" id="editBannerClose" aria-label="Đóng">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="6" x2="6" y2="18"/>
                    <line x1="6" y1="6" x2="18" y2="18"/>
                </svg>
            </button>
        </div>
        <form id="editBannerForm" class="admin-form">
            <input type="hidden" id="editBannerId">
            <div class="admin-form__group" style="margin-bottom:16px;">
                <label class="admin-form__label">Tiêu đề <span>*</span></label>
                <input type="text" id="editBannerTitle" required class="admin-form__input">
            </div>
            <div class="admin-form__group" style="margin-bottom:16px;">
                <label class="admin-form__label">Phụ đề</label>
                <input type="text" id="editBannerSubtitle" class="admin-form__input">
            </div>
            <div class="admin-form__group" style="margin-bottom:16px;">
                <label class="admin-form__label">Link URL</label>
                <input type="text" id="editBannerLinkUrl" class="admin-form__input">
            </div>
            <div class="admin-form__group" style="margin-bottom:16px;">
                <label class="admin-form__label">Thay đổi hình ảnh</label>
                <input type="file" id="editBannerImage" accept="image/*" class="admin-form__input">
                <p style="font-size:12px;color:#888;margin-top:4px;">Để trống nếu không muốn đổi ảnh</p>
            </div>
            <div class="admin-modal__buttons">
                <button type="button" class="admin-btn admin-btn--ghost" id="editBannerCancel">Hủy</button>
                <button type="submit" class="admin-btn admin-btn--primary">Lưu thay đổi</button>
            </div>
        </form>
    </div>
</div>

<script type="application/json" id="bannersBootstrap"><%- JSON.stringify(
    (banners || []).map(b => ({ id: b.id, title: b.title || '', subtitle: b.subtitle || '', link_url: b.link_url || '', image_url: b.image_url || '' }))
).replace(/</g, '\u003c') %></script>

<script src="/js/admin/banners.js"></script>

<%- include('../partials/admin-footer') %>
