<%# Partial EJS dùng lại cho chat widget để các view giữ cấu trúc thống nhất. %>
<!-- Chat Widget - Được include trong footer.ejs -->
<!-- ===== Khung tổng của chat widget nổi ===== -->
<%
    const chatSettings = typeof storefrontSettings !== 'undefined' && storefrontSettings ? storefrontSettings : {};
    const chatTitle = chatSettings.chat_title || chatSettings.site_name || 'WIND OF FALL';
    const chatInitials = chatSettings.brand_initials || 'WF';
    const chatPosition = chatSettings.chat_position === 'left' ? 'left' : 'right';
%>
<div id="chatWidget" class="chat-widget chat-widget--<%= chatPosition %>">
    <!-- Nút bật/tắt khung chat -->
    <button class="chat-widget__toggle" id="chatToggleBtn" type="button">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
        </svg>
        <span class="chat-widget__badge" id="chatBadge" hidden>0</span>
    </button>

    <!-- Khung nội dung chat -->
    <div class="chat-widget__box" id="chatBox" hidden>
        <div class="chat-widget__header">
            <div class="chat-widget__header-info">
                <div class="chat-widget__avatar"><%= chatInitials %></div>
                <div>
                    <div class="chat-widget__title"><%= chatTitle %></div>
                    <div class="chat-widget__status">
                        <span class="chat-widget__dot"></span> Trực tuyến
                    </div>
                </div>
            </div>
            <div class="chat-widget__header-actions">
                <button class="chat-widget__action-btn" id="chatExpandBtn" type="button" aria-label="Phóng to cửa sổ chat">
                    <svg class="chat-widget__action-icon chat-widget__action-icon--expand" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="15 3 21 3 21 9"></polyline>
                        <polyline points="9 21 3 21 3 15"></polyline>
                        <line x1="21" y1="3" x2="14" y2="10"></line>
                        <line x1="3" y1="21" x2="10" y2="14"></line>
                    </svg>
                    <svg class="chat-widget__action-icon chat-widget__action-icon--collapse" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" hidden>
                        <polyline points="9 3 3 3 3 9"></polyline>
                        <polyline points="15 21 21 21 21 15"></polyline>
                        <line x1="3" y1="3" x2="10" y2="10"></line>
                        <line x1="21" y1="21" x2="14" y2="14"></line>
                    </svg>
                </button>
                <button class="chat-widget__close" type="button">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                    </svg>
                </button>
            </div>
        </div>

        <!-- Vùng danh sách tin nhắn (được render bởi chat-widget.js) -->
        <div class="chat-widget__messages" id="chatMessages">
            <div class="chat-widget__welcome">
                <p><%= chatSettings.chat_greeting || 'Xin chào! Tôi là trợ lý AI của WIND OF FALL.' %></p>
                <p><%= chatSettings.chat_prompt_text || 'Bạn cần hỗ trợ gì?' %></p>
            </div>
        </div>

        <div class="chat-widget__input-area">
            <!-- Vùng soạn tin: văn bản + tệp đính kèm media -->
            <form id="chatForm">
                <button type="button" class="chat-widget__attach-btn" id="chatAttachBtn" aria-label="Gửi ảnh hoặc video">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21.44 11.05l-8.49 8.49a5.5 5.5 0 0 1-7.78-7.78l9.19-9.19a3.5 3.5 0 0 1 4.95 4.95l-9.2 9.19a1.5 1.5 0 0 1-2.12-2.12l8.49-8.48"/>
                    </svg>
                </button>
                <input type="text" id="chatInput" placeholder="Nhập tin nhắn..."
                       autocomplete="off" maxlength="500">
                <input type="file" id="chatMediaInput" name="messageMedia" accept="image/*,video/*" multiple hidden>
                <button type="submit" id="chatSendBtn">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="22" y1="2" x2="11" y2="13"/>
                        <polygon points="22 2 15 22 11 13 2 9 22 2"/>
                    </svg>
                </button>
            </form>
            <div class="chat-widget__attachments" id="chatAttachmentPreview" hidden>
                <div class="chat-widget__attachments-media" id="chatAttachmentPreviewMedia"></div>
                <div class="chat-widget__attachments-meta">
                    <span class="chat-widget__attachments-text" id="chatAttachmentPreviewText"></span>
                    <button type="button" class="chat-widget__attachments-clear" id="chatAttachmentClearBtn">Bỏ chọn</button>
                </div>
            </div>
        </div>
    </div>
</div>
