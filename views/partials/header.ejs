<%# Partial EJS dùng lại cho header để các view giữ cấu trúc thống nhất. %>
<!DOCTYPE html>
<html lang="vi">
<%
    const extraPageStyles = Array.isArray(typeof pageStyles !== 'undefined' ? pageStyles : null) ? pageStyles : [];
    const websiteSettings = typeof storefrontSettings !== 'undefined' && storefrontSettings ? storefrontSettings : {};
    const siteName = websiteSettings.site_name || 'WIND OF FALL';
    const siteTagline = websiteSettings.site_tagline || 'Thời trang mặc đẹp mỗi ngày';
    const brandAltText = websiteSettings.brand_alt_text || siteName;
    const logoUrl = websiteSettings.logo_url || '/favicon.png';
    const faviconUrl = websiteSettings.favicon_url || '/favicon.png';
    const seoTitle = websiteSettings.seo_title || `${siteName} | Thời trang mỗi ngày`;
    const metaDescription = websiteSettings.meta_description || `${siteName} - mua sắm thời trang everyday.`;
    const robotsContent = websiteSettings.robots_index === false ? 'noindex,nofollow' : 'index,follow';
    const cardRadius = Number.isFinite(Number(websiteSettings.card_radius)) ? Number(websiteSettings.card_radius) : 20;
    const buttonRadius = Number.isFinite(Number(websiteSettings.button_radius)) ? Number(websiteSettings.button_radius) : 999;
    const brandNameFontSize = Number.isFinite(Number(websiteSettings.brand_name_font_size)) ? Number(websiteSettings.brand_name_font_size) : 18;
%>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= seoTitle %></title>
    <meta name="description" content="<%= metaDescription %>">
    <meta name="keywords" content="<%= websiteSettings.meta_keywords || '' %>">
    <meta name="robots" content="<%= robotsContent %>">
    <meta property="og:title" content="<%= websiteSettings.og_title || siteName %>">
    <meta property="og:description" content="<%= websiteSettings.og_description || metaDescription %>">
    <meta property="og:image" content="<%= websiteSettings.og_image_url || faviconUrl %>">
    <link rel="icon" type="image/png" href="<%= faviconUrl %>">
    <link rel="shortcut icon" href="<%= faviconUrl %>">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800&family=Inter:wght@400;500;600;700;800&family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --font-family: <%- websiteSettings.site_font_family || "'Be Vietnam Pro', sans-serif" %>;
            --accent: <%= websiteSettings.primary_color || '#f2c94c' %>;
            --accent-strong: <%= websiteSettings.secondary_color || '#d8a617' %>;
            --paper: <%= websiteSettings.background_color || '#fcfaf4' %>;
            --ink: <%= websiteSettings.text_color || '#18140d' %>;
            --radius-md: <%= cardRadius %>px;
            --radius-full: <%= buttonRadius %>px;
            --brand-font-family: <%- websiteSettings.brand_font_family || "'Be Vietnam Pro', sans-serif" %>;
            --brand-name-font-size: <%= brandNameFontSize %>px;
        }
    </style>
    <% extraPageStyles.forEach((href) => { %>
        <link rel="stylesheet" href="<%= href %>">
    <% }) %>
</head>
<body data-user-authenticated="<%= user ? 'true' : 'false' %>">
<%
    const currentUrl = typeof path === 'string' ? path : '';
    const currentPath = currentUrl.split('?')[0];
    const currentCategory = typeof category !== 'undefined' ? category : null;
    const categorySlug = currentCategory ? currentCategory.slug : '';
    const navigationCategories = Array.isArray(typeof headerCategories !== 'undefined' ? headerCategories : null) ? headerCategories : [];
    const isSalePageActive = typeof isSalePage !== 'undefined' ? isSalePage : currentUrl.includes('sale=true');
    const isProfilePage = currentPath === '/auth/profile';
    const isOrdersPage = currentPath === '/orders/history';
    const isCartPage = currentPath === '/cart';
    const isForYouPage = currentPath === '/products/for-you';

    function isCategoryBranchActive(branch) {
        if (!branch || !categorySlug) {
            return false;
        }

        if (branch.slug === categorySlug) {
            return true;
        }

        return Array.isArray(branch.children) && branch.children.some((child) => child.slug === categorySlug);
    }
%>

<header class="header">
    <div class="header-main">
        <div class="container header-main__inner">
            <a href="/" class="header-brand" aria-label="<%= brandAltText %>">
                <img src="<%= logoUrl %>" alt="<%= brandAltText %>" class="header-brand__mark">
                <span class="header-brand__text">
                    <strong><%= siteName %></strong>
                    <small><%= siteTagline %></small>
                </span>
            </a>

            <div class="header-search">
                <form action="/products/search" method="GET" autocomplete="off">
                    <input type="text" name="q" id="searchInput" placeholder="<%= websiteSettings.search_placeholder || 'Tìm áo polo, váy midi, quần jean...' %>" required>
                    <button type="submit" aria-label="Tìm kiếm">
                        <svg width="18" height="18" viewBox="0 0 20 20" fill="none">
                            <path d="M9 17A8 8 0 1 0 9 1a8 8 0 0 0 0 16zM18 18l-4.35-4.35" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                        </svg>
                    </button>
                </form>
                <div class="search-suggest" id="searchSuggest"></div>
            </div>

            <div class="header-actions">
                <% if (user) { %>
                    <% if (user.role === 'admin') { %>
                        <a href="/admin/dashboard" class="admin-badge" title="Quản trị">Admin</a>
                    <% } %>
                    <a href="/auth/profile" class="icon-btn <%= isProfilePage ? 'icon-btn--active' : '' %>" title="Tài khoản">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2M12 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8z" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                        </svg>
                        <span class="icon-label">Tài khoản</span>
                    </a>
                    <a href="/orders/history" class="icon-btn <%= isOrdersPage ? 'icon-btn--active' : '' %>" title="Đơn hàng">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                            <path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2M9 5a2 2 0 0 0 2 2h2a2 2 0 0 0 2-2M9 5a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2M9 12h6M9 16h6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                        </svg>
                        <span class="icon-label">Đơn hàng</span>
                    </a>
                    <a href="/cart" class="icon-btn cart-btn <%= isCartPage ? 'icon-btn--active' : '' %>" title="Giỏ hàng">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                            <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            <line x1="3" y1="6" x2="21" y2="6" stroke="currentColor" stroke-width="2"/>
                            <path d="M16 10a4 4 0 0 1-8 0" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                        </svg>
                        <span class="icon-label">Giỏ hàng</span>
                        <span class="cart-count" id="cart-count">0</span>
                    </a>
                    <form action="/auth/logout" method="POST" class="logout-form">
                        <button type="submit" class="icon-btn logout-btn" title="Đăng xuất">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4M16 17l5-5-5-5M21 12H9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                            <span class="icon-label">Thoát</span>
                        </button>
                    </form>
                <% } else { %>
                    <a href="/auth/login" class="auth-link" title="Đăng nhập">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2M12 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8z" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                        </svg>
                        <span>Đăng nhập / Đăng ký</span>
                    </a>
                    <a href="/cart" class="icon-btn cart-btn <%= isCartPage ? 'icon-btn--active' : '' %>" title="Giỏ hàng">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                            <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            <line x1="3" y1="6" x2="21" y2="6" stroke="currentColor" stroke-width="2"/>
                            <path d="M16 10a4 4 0 0 1-8 0" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                        </svg>
                        <span class="cart-count" id="cart-count">0</span>
                    </a>
                <% } %>

                <button class="mobile-menu-btn" id="mobileMenuBtn" aria-label="Mở menu">
                    <span></span>
                    <span></span>
                    <span></span>
                </button>
            </div>
        </div>
    </div>

    <div class="header-nav">
        <div class="container header-nav__inner">
            <nav class="main-nav">
                <a href="/" class="<%= currentPath === '/' ? 'active' : '' %>"><%= websiteSettings.home_link_label || 'Trang chủ' %></a>
                <% navigationCategories.forEach((headerCategory) => { %>
                    <% const branchActive = isCategoryBranchActive(headerCategory); %>
                    <div class="main-nav__item <%= Array.isArray(headerCategory.children) && headerCategory.children.length > 0 ? 'main-nav__item--has-dropdown' : '' %>">
                        <a
                            href="/products/category/<%= headerCategory.slug %>"
                            class="main-nav__trigger <%= branchActive ? 'active' : '' %>"
                            <%= Array.isArray(headerCategory.children) && headerCategory.children.length > 0 ? 'aria-haspopup="true" aria-expanded="false"' : '' %>
                        ><%= headerCategory.name %></a>
                        <% if (Array.isArray(headerCategory.children) && headerCategory.children.length > 0) { %>
                            <div class="main-nav__dropdown">
                                <% headerCategory.children.forEach((childCategory) => { %>
                                    <a href="/products/category/<%= childCategory.slug %>" class="<%= categorySlug === childCategory.slug ? 'active' : '' %>"><%= childCategory.name %></a>
                                <% }) %>
                            </div>
                        <% } %>
                    </div>
                <% }) %>
                <% if (websiteSettings.show_all_products_link !== false) { %>
                    <a href="/products" class="<%= currentPath === '/products' ? 'active' : '' %>"><%= websiteSettings.all_products_label || 'Tất cả' %></a>
                <% } %>
                <% if (websiteSettings.show_sale_link !== false) { %>
                    <a href="/products?sale=true" class="sale-link <%= isSalePageActive ? 'active' : '' %>"><%= websiteSettings.sale_link_label || 'Sale tới 50%' %></a>
                <% } %>
                <% if (websiteSettings.show_for_you_link !== false) { %>
                    <a href="/products/for-you" class="<%= isForYouPage ? 'active' : '' %>"><%= websiteSettings.for_you_link_label || 'For You' %></a>
                <% } %>
            </nav>
        </div>
    </div>

    <div class="container mobile-header-search">
        <form action="/products/search" method="GET">
            <input type="text" name="q" placeholder="<%= websiteSettings.mobile_search_placeholder || 'Tìm sản phẩm yêu thích...' %>" required>
            <button type="submit" aria-label="Tìm kiếm">
                <svg width="18" height="18" viewBox="0 0 20 20" fill="none">
                    <path d="M9 17A8 8 0 1 0 9 1a8 8 0 0 0 0 16zM18 18l-4.35-4.35" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
            </button>
        </form>
    </div>
</header>

<div class="mobile-nav-overlay" id="mobileNavOverlay"></div>

<nav class="mobile-nav" id="mobileNav">
    <div class="mobile-nav__header">
        <div>
            <span class="mobile-nav__eyebrow"><%= websiteSettings.mobile_menu_eyebrow || siteName %></span>
            <strong class="mobile-nav__logo"><%= websiteSettings.mobile_menu_slogan || siteTagline %></strong>
        </div>
        <button class="mobile-nav__close" id="mobileNavClose" aria-label="Đóng menu">&times;</button>
    </div>

    <div class="mobile-nav__search">
        <form action="/products/search" method="GET">
            <input type="text" name="q" placeholder="<%= websiteSettings.mobile_search_placeholder || 'Tìm áo, váy, quần...' %>" required>
            <button type="submit" aria-label="Tìm kiếm">
                <svg width="18" height="18" viewBox="0 0 20 20" fill="none">
                    <path d="M9 17A8 8 0 1 0 9 1a8 8 0 0 0 0 16zM18 18l-4.35-4.35" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
            </button>
        </form>
    </div>

    <div class="mobile-nav__links">
        <a href="/" class="<%= currentPath === '/' ? 'active' : '' %>"><%= websiteSettings.home_link_label || 'Trang chủ' %></a>
        <% navigationCategories.forEach((headerCategory) => { %>
            <div class="mobile-nav__group">
                <a href="/products/category/<%= headerCategory.slug %>" class="<%= isCategoryBranchActive(headerCategory) ? 'active' : '' %>"><%= headerCategory.name %></a>
                <% if (Array.isArray(headerCategory.children) && headerCategory.children.length > 0) { %>
                    <div class="mobile-nav__children">
                        <% headerCategory.children.forEach((childCategory) => { %>
                            <a href="/products/category/<%= childCategory.slug %>" class="<%= categorySlug === childCategory.slug ? 'active' : '' %>"><%= childCategory.name %></a>
                        <% }) %>
                    </div>
                <% } %>
            </div>
        <% }) %>
        <% if (websiteSettings.show_all_products_link !== false) { %>
            <a href="/products"><%= websiteSettings.all_products_label || 'Tất cả sản phẩm' %></a>
        <% } %>
        <% if (websiteSettings.show_sale_link !== false) { %>
            <a href="/products?sale=true" class="sale-link <%= isSalePageActive ? 'active' : '' %>"><%= websiteSettings.sale_link_label || 'Khu sale' %></a>
        <% } %>
        <% if (websiteSettings.show_for_you_link !== false) { %>
            <a href="/products/for-you" class="<%= isForYouPage ? 'active' : '' %>"><%= websiteSettings.for_you_link_label || 'For You' %></a>
        <% } %>
    </div>

    <div class="mobile-nav__actions">
        <% if (user) { %>
            <% if (user.role === 'admin') { %>
                <a href="/admin/dashboard" class="admin-badge">Quản trị</a>
            <% } %>
            <a href="/auth/profile">Tài khoản của tôi</a>
            <a href="/orders/history">Đơn hàng của tôi</a>
            <a href="/cart">Giỏ hàng</a>
            <form action="/auth/logout" method="POST" class="mobile-nav__logout-form">
                <button type="submit" class="mobile-nav__logout-btn">Đăng xuất</button>
            </form>
        <% } else { %>
            <a href="/auth/login">Đăng nhập</a>
            <a href="/auth/register">Đăng ký</a>
            <a href="/cart">Giỏ hàng</a>
        <% } %>
    </div>

    <div class="mobile-nav__footer">
        <p><%= websiteSettings.mobile_support_text || 'Hỗ trợ tư vấn set đồ 1:1 qua hotline 1900 123 456' %></p>
    </div>
</nav>

<main>
