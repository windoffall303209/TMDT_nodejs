<%# Partial EJS dùng lại cho footer để các view giữ cấu trúc thống nhất. %>
</main>
<%
    const extraPageScripts = Array.isArray(typeof pageScripts !== 'undefined' ? pageScripts : null) ? pageScripts : [];
    const footerSettings = typeof storefrontSettings !== 'undefined' && storefrontSettings ? storefrontSettings : {};
    const footerSiteName = footerSettings.site_name || 'WIND OF FALL';
    const footerInitials = footerSettings.brand_initials || 'WF';
    const footerLogoUrl = footerSettings.logo_url || footerSettings.favicon_url || '/favicon.png';
    const footerPayments = Array.isArray(footerSettings.payment_badges) ? footerSettings.payment_badges : ['COD', 'VNPay', 'MoMo', 'Visa'];
    const footerPolicyLinks = Array.isArray(footerSettings.policy_links) && footerSettings.policy_links.length > 0
        ? footerSettings.policy_links
        : [
            { label: 'Vận chuyển', url: '/policy/shipping' },
            { label: 'Đổi trả', url: '/policy/return' },
            { label: 'Thanh toán', url: '/policy/payment' },
            { label: 'Bảo mật thông tin', url: '/policy/privacy' }
        ];
%>

<!-- ===== Footer: dải dịch vụ, liên kết, scripts ===== -->
<footer class="footer">
    <section class="footer-service-strip">
        <div class="container footer-service-strip__grid">
            <div class="footer-service-card">
                <strong><%= footerSettings.service_shipping_title || 'Freeship đơn từ 499K' %></strong>
                <p><%= footerSettings.service_shipping_copy || 'Giao nhanh tại thành phố lớn, theo dõi hành trình đơn hàng rõ ràng.' %></p>
            </div>
            <div class="footer-service-card">
                <strong><%= footerSettings.service_return_title || 'Đổi trả 30 ngày' %></strong>
                <p><%= footerSettings.service_return_copy || 'Hỗ trợ đổi size, đổi màu và hoàn tiền theo chính sách minh bạch.' %></p>
            </div>
            <div class="footer-service-card">
                <strong><%= footerSettings.service_consult_title || 'Tư vấn chọn đồ' %></strong>
                <p><%= footerSettings.service_consult_copy || 'Hotline và chat luôn sẵn sàng để chốt size và set outfit phù hợp.' %></p>
            </div>
        </div>
    </section>

    <!-- Các cột nội dung chính của footer -->
    <div class="footer-main">
        <div class="container footer-grid">
            <div class="footer-branding">
                <div class="footer-branding__logo">
                    <span class="footer-branding__logo-mark" aria-hidden="true">
                        <% if (footerLogoUrl) { %>
                            <img src="<%= footerLogoUrl %>" alt="">
                        <% } else { %>
                            <%= footerInitials %>
                        <% } %>
                    </span>
                    <strong><%= footerSiteName %></strong>
                </div>
                <p class="footer-branding__text">
                    <%= footerSettings.footer_description || 'Thương hiệu thời trang everyday theo tinh thần hiện đại, gọn gàng và dễ mặc.' %>
                </p>
                <div class="footer-socials">
                    <% if (footerSettings.facebook_url !== '') { %><a href="<%= footerSettings.facebook_url || '#' %>" title="Facebook">Facebook</a><% } %>
                    <% if (footerSettings.instagram_url !== '') { %><a href="<%= footerSettings.instagram_url || '#' %>" title="Instagram">Instagram</a><% } %>
                    <% if (footerSettings.tiktok_url !== '') { %><a href="<%= footerSettings.tiktok_url || '#' %>" title="TikTok">TikTok</a><% } %>
                    <% if (footerSettings.zalo_url) { %><a href="<%= footerSettings.zalo_url %>" title="Zalo">Zalo</a><% } %>
                </div>
            </div>

            <div class="footer-col">
                <h4>Mua sắm</h4>
                <ul>
                    <li><a href="/products/category/nam">Thời trang nam</a></li>
                    <li><a href="/products/category/nu">Thời trang nữ</a></li>
                    <li><a href="/products/category/tre-em">Trẻ em</a></li>
                    <li><a href="/products?sale=true">Khu sale</a></li>
                </ul>
            </div>

            <div class="footer-col">
                <h4>Hỗ trợ khách hàng</h4>
                <ul>
                    <% footerPolicyLinks.forEach((link) => { %>
                        <% if (link && link.label && link.url) { %>
                            <li><a href="<%= link.url %>"><%= link.label %></a></li>
                        <% } %>
                    <% }) %>
                </ul>
            </div>

            <div class="footer-col">
                <h4>Liên hệ</h4>
                <ul>
                    <li><a href="tel:<%= String(footerSettings.contact_hotline || '1900123456').replace(/\s+/g, '') %>">Hotline: <%= footerSettings.contact_hotline || '1900 123 456' %></a></li>
                    <li><a href="mailto:<%= footerSettings.contact_email || 'info@windoffall.vn' %>"><%= footerSettings.contact_email || 'info@windoffall.vn' %></a></li>
                    <li><a href="#"><%= footerSettings.contact_address || '123 Nguyễn Huệ, Quận 1, TP.HCM' %></a></li>
                    <li><a href="#"><%= footerSettings.opening_hours || 'Mở cửa 8:00 - 22:00 mỗi ngày' %></a></li>
                </ul>
            </div>
        </div>
    </div>

    <div class="footer-bottom">
        <div class="container footer-bottom__inner">
            <p><%= footerSettings.copyright_text || '© 2026 WIND OF FALL. All rights reserved.' %></p>
            <div class="payment-methods">
                <% footerPayments.forEach((payment) => { %>
                    <span class="payment-badge"><%= payment %></span>
                <% }) %>
            </div>
        </div>
    </div>
</footer>

<% if (footerSettings.chat_enabled !== false) { %>
    <%- include('chat-widget') %>
<% } %>

<% if (footerSettings.chat_enabled !== false) { %>
<link rel="stylesheet" href="/css/chat-rich-message.css">
<link rel="stylesheet" href="/css/chat-widget.css?v=chat-unified-input-20260521">
<% } %>
<script src="/js/toast.js"></script>
<script src="/js/main.js"></script>
<script src="/js/search-suggest.js?v=prefix-one-char-search-20260521"></script>
<% if (footerSettings.chat_enabled !== false) { %>
<script src="/js/chat-rich-message.js"></script>
<script src="/js/chat-widget.js?v=chat-minimal-20260521"></script>
<% } %>
<% extraPageScripts.forEach((src) => { %>
<script src="<%= src %>"></script>
<% }) %>
</body>
</html>
