<%
    const productSlug = product.slug || product.id;
    const productPrice = Number(product.price || 0);
    const productFinalPrice = Number(product.final_price || productPrice);
    const hasDiscount = productFinalPrice < productPrice;
    const isNewProduct = product.created_at && (new Date() - new Date(product.created_at)) < 7 * 24 * 60 * 60 * 1000;
    const colorOptions = product.variants
        ? [...new Set(product.variants.map(variant => variant.color).filter(Boolean))].slice(0, 3)
        : [];
%>

<article class="product-card">
    <a href="/products/<%= productSlug %>" class="product-card__link">
        <div class="product-card__image">
            <% if (product.sale_type) { %>
                <span class="product-card__badge product-card__badge--sale">
                    <% if (product.sale_type === 'percentage') { %>
                        -<%= product.sale_value %>%
                    <% } else { %>
                        Sale
                    <% } %>
                </span>
            <% } %>

            <% if (product.stock_quantity === 0) { %>
                <span class="product-card__badge product-card__badge--soldout">Hết hàng</span>
            <% } else if (isNewProduct) { %>
                <span class="product-card__badge product-card__badge--new">Mới</span>
            <% } %>

            <% if (product.primary_image) { %>
                <img
                    class="img-primary"
                    src="<%= product.card_image || product.primary_image %>"
                    alt="<%= product.name %>"
                    loading="lazy"
                    decoding="async"
                    fetchpriority="low"
                >
            <% } else { %>
                <div class="product-card__image-placeholder">
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                        <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                        <circle cx="8.5" cy="8.5" r="1.5"/>
                        <polyline points="21,15 16,10 5,21"/>
                    </svg>
                </div>
            <% } %>

            <% if (product.secondary_image) { %>
                <img
                    class="img-secondary"
                    src="<%= product.secondary_image %>"
                    alt="<%= product.name %>"
                    loading="lazy"
                    decoding="async"
                    fetchpriority="low"
                >
            <% } else if (product.images && product.images.length > 1) { %>
                <img
                    class="img-secondary"
                    src="<%= product.images[1] %>"
                    alt="<%= product.name %>"
                    loading="lazy"
                    decoding="async"
                    fetchpriority="low"
                >
            <% } %>

            <button class="product-card__quick-add" data-product-id="<%= product.id %>" <% if (product.stock_quantity === 0) { %>disabled<% } %>>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="9" cy="21" r="1"/>
                    <circle cx="20" cy="21" r="1"/>
                    <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
                </svg>
                <span>Thêm vào giỏ</span>
            </button>
        </div>

        <div class="product-card__info">
            <div class="product-card__meta">
                <span class="product-card__collection"><%= product.category_name || 'WIND OF FALL' %></span>
                <% if (product.review_count > 0) { %>
                    <span class="product-card__rating"><%= Number(product.average_rating || 0).toFixed(1) %> / 5</span>
                <% } %>
            </div>

            <h3 class="product-card__name"><%= product.name %></h3>

            <% if (colorOptions.length > 0) { %>
                <div class="product-card__tags">
                    <% colorOptions.forEach(color => { %>
                        <span class="product-card__tag"><%= color %></span>
                    <% }) %>
                </div>
            <% } %>

            <div class="product-card__price-row">
                <% if (hasDiscount) { %>
                    <span class="product-card__price-original"><%= productPrice.toLocaleString('vi-VN') %>đ</span>
                    <span class="product-card__price product-card__price--sale"><%= productFinalPrice.toLocaleString('vi-VN') %>đ</span>
                <% } else { %>
                    <span class="product-card__price"><%= productPrice.toLocaleString('vi-VN') %>đ</span>
                <% } %>
            </div>
        </div>
    </a>
</article>
