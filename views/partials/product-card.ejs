<%# Partial EJS dùng lại cho sản phẩm card để các view giữ cấu trúc thống nhất. %>
<%
    const productSlug = product.slug || product.id;
    const productPrice = Number(product.price || 0);
    const productFinalPrice = Number(product.display_price || product.final_price || productPrice);
    const hasDiscount = productFinalPrice < productPrice;
    const isNewProduct = product.created_at && (new Date() - new Date(product.created_at)) < 7 * 24 * 60 * 60 * 1000;
    const promotionStatus = String(product.promotion_status || 'none');
    const averageRating = Number(product.average_rating || 0);
    const soldCount = Math.max(0, Number.parseInt(product.sold_count, 10) || 0);
    const hasMeta = averageRating > 0 || soldCount > 0;
    const formatSoldCount = (value) => {
        if (value >= 1000000) {
            return `${(value / 1000000).toFixed(value % 1000000 === 0 ? 0 : 1)}M`;
        }

        if (value >= 1000) {
            return `${(value / 1000).toFixed(value % 1000 === 0 ? 0 : 1)}k`;
        }

        return value.toLocaleString('vi-VN');
    };
%>

<article class="product-card">
    <a href="/products/<%= productSlug %>" class="product-card__link">
        <div class="product-card__image">
            <% if (product.sale_type) { %>
                <span class="product-card__badge product-card__badge--sale">
                    <% if (product.sale_type === 'percentage') { %>
                        -<%= product.sale_value %>%
                    <% } else { %>
                        Sale
                    <% } %>
                </span>
            <% } else if (promotionStatus === 'upcoming') { %>
                <span class="product-card__badge product-card__badge--upcoming">S&#7855;p gi&#7843;m gi&#225;</span>
            <% } %>

            <% if (product.stock_quantity === 0) { %>
                <span class="product-card__badge product-card__badge--soldout">H&#7871;t h&#224;ng</span>
            <% } else if (isNewProduct) { %>
                <span class="product-card__badge product-card__badge--new">M&#7899;i</span>
            <% } %>

            <% if (product.primary_image) { %>
                <img
                    class="img-primary"
                    src="<%= product.card_image || product.primary_image %>"
                    alt="<%= product.name %>"
                    loading="lazy"
                    decoding="async"
                    fetchpriority="low"
                >
            <% } else { %>
                <div class="product-card__image-placeholder">
                    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                        <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                        <circle cx="8.5" cy="8.5" r="1.5"/>
                        <polyline points="21,15 16,10 5,21"/>
                    </svg>
                </div>
            <% } %>

            <% if (product.secondary_image) { %>
                <img
                    class="img-secondary"
                    src="<%= product.secondary_image %>"
                    alt="<%= product.name %>"
                    loading="lazy"
                    decoding="async"
                    fetchpriority="low"
                >
            <% } else if (product.images && product.images.length > 1) { %>
                <img
                    class="img-secondary"
                    src="<%= product.images[1] %>"
                    alt="<%= product.name %>"
                    loading="lazy"
                    decoding="async"
                    fetchpriority="low"
                >
            <% } %>

            <button class="product-card__quick-add" data-product-id="<%= product.id %>" <% if (product.stock_quantity === 0) { %>disabled<% } %>>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="9" cy="21" r="1"/>
                    <circle cx="20" cy="21" r="1"/>
                    <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
                </svg>
                <span>Th&#234;m v&#224;o gi&#7887;</span>
            </button>
        </div>

        <div class="product-card__info">
            <h3 class="product-card__name"><%= product.name %></h3>

            <div class="product-card__meta-row <%= hasMeta ? '' : 'product-card__meta-row--empty' %>">
                <% if (hasMeta) { %>
                    <span class="product-card__meta">
                        <% if (averageRating > 0) { %>
                            <span class="product-card__meta-rating"><%= averageRating.toFixed(1) %></span>
                            <span class="product-card__meta-star" aria-hidden="true">&#9733;</span>
                        <% } %>
                        <% if (averageRating > 0 && soldCount > 0) { %>
                            <span class="product-card__meta-separator">|</span>
                        <% } %>
                        <% if (soldCount > 0) { %>
                            <span class="product-card__meta-sold"><%= formatSoldCount(soldCount) %> &#273;&#227; b&#225;n</span>
                        <% } %>
                    </span>
                <% } else { %>
                    <span class="product-card__meta-spacer" aria-hidden="true"></span>
                <% } %>
            </div>

            <div class="product-card__price-row">
                <% if (hasDiscount) { %>
                    <span class="product-card__price product-card__price--sale"><%= productFinalPrice.toLocaleString('vi-VN') %>&#273;</span>
                    <span class="product-card__price-original"><%= productPrice.toLocaleString('vi-VN') %>&#273;</span>
                <% } else { %>
                    <span class="product-card__price"><%= productPrice.toLocaleString('vi-VN') %>&#273;</span>
                <% } %>
            </div>
        </div>
    </a>
</article>
