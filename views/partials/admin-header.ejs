<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin - WIND OF FALL</title>
    <link rel="icon" type="image/jpeg" href="https://res.cloudinary.com/drs7xrtxo/image/upload/v1773135637/z7606467693465_9fdaa8e775a54c925e4ce37b258ca07b_yo7jhg.jpg">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/admin.css">
    <link rel="stylesheet" href="/css/admin-animations.css">
</head>
<body class="admin-body">

<header class="admin-header">
    <div class="container">
        <div class="logo">
            <a href="/admin/dashboard">
                WIND OF FALL
                <span>Admin</span>
            </a>
        </div>
        
        <nav class="admin-nav">
            <a href="/admin/dashboard" class="<%= currentPage === 'dashboard' ? 'active' : '' %>">Dashboard</a>
            <a href="/admin/products" class="<%= currentPage === 'products' ? 'active' : '' %>">Sản Phẩm</a>
            <a href="/admin/orders" class="<%= currentPage === 'orders' ? 'active' : '' %>">Đơn Hàng</a>
            <a href="/admin/users" class="<%= currentPage === 'users' ? 'active' : '' %>">Người Dùng</a>
            <a href="/admin/banners" class="<%= currentPage === 'banners' ? 'active' : '' %>">Banners</a>
            <a href="/admin/sales" class="<%= currentPage === 'sales' ? 'active' : '' %>">Khuyến Mãi</a>
            <a href="/admin/vouchers" class="<%= currentPage === 'vouchers' ? 'active' : '' %>">Voucher</a>
        </nav>
        
        <div class="admin-actions">
            <% if (user) { %>
                <span class="user-info"><%= user.email %></span>
            <% } %>
            <a href="/" class="btn-store">
                <svg class="btn-store__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                    <polyline points="9 22 9 12 15 12 15 22"/>
                </svg>
                <span class="btn-store__text">Xem Store</span>
            </a>
            <a href="/auth/logout" class="btn-logout" title="Đăng xuất">
                <svg class="btn-logout__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                    <polyline points="16 17 21 12 16 7"/>
                    <line x1="21" y1="12" x2="9" y2="12"/>
                </svg>
                <span class="btn-logout__text">Đăng xuất</span>
            </a>

            <!-- Admin Mobile Menu Button -->
            <button class="admin-mobile-menu-btn" id="adminMobileMenuBtn" aria-label="Menu">
                <span></span>
                <span></span>
                <span></span>
            </button>
        </div>
    </div>
</header>

<!-- Admin Mobile Navigation Overlay -->
<div class="admin-mobile-overlay" id="adminMobileOverlay"></div>

<!-- Admin Mobile Navigation -->
<nav class="admin-mobile-nav" id="adminMobileNav">
    <a href="/admin/dashboard" class="<%= currentPage === 'dashboard' ? 'active' : '' %>">
        📊 Dashboard
    </a>
    <a href="/admin/products" class="<%= currentPage === 'products' ? 'active' : '' %>">
        📦 Sản Phẩm
    </a>
    <a href="/admin/orders" class="<%= currentPage === 'orders' ? 'active' : '' %>">
        🛒 Đơn Hàng
    </a>
    <a href="/admin/users" class="<%= currentPage === 'users' ? 'active' : '' %>">
        👥 Người Dùng
    </a>
    <a href="/admin/banners" class="<%= currentPage === 'banners' ? 'active' : '' %>">
        🖼️ Banners
    </a>
    <a href="/admin/sales" class="<%= currentPage === 'sales' ? 'active' : '' %>">
        🏷️ Khuyến Mãi
    </a>
    <a href="/admin/vouchers" class="<%= currentPage === 'vouchers' ? 'active' : '' %>">
        🎟️ Voucher
    </a>
    <div class="admin-mobile-nav__divider"></div>
    <a href="/">
        🏠 Xem Store
    </a>
    <a href="/auth/logout" style="color: #ef4444;">
        🚪 Đăng xuất
    </a>
</nav>

<main style="background: #f5f5f5; min-height: calc(100vh - 60px);">

<script>
// Admin Mobile Menu - IIFE to work regardless of script loading order
(function() {
    var savedScrollY = 0;

    function initAdminMobileMenu() {
        var adminMobileMenuBtn = document.getElementById('adminMobileMenuBtn');
        var adminMobileNav = document.getElementById('adminMobileNav');
        var adminMobileOverlay = document.getElementById('adminMobileOverlay');

        if (!adminMobileMenuBtn || !adminMobileNav) return;

        // Prevent duplicate initialization
        if (adminMobileMenuBtn.dataset.initialized) return;
        adminMobileMenuBtn.dataset.initialized = 'true';

        function openAdminMenu() {
            savedScrollY = window.scrollY;
            adminMobileMenuBtn.classList.add('active');
            adminMobileNav.classList.add('active');
            if (adminMobileOverlay) adminMobileOverlay.classList.add('active');
            document.body.classList.add('admin-menu-open');
            document.body.style.top = '-' + savedScrollY + 'px';
        }

        function closeAdminMenu() {
            adminMobileMenuBtn.classList.remove('active');
            adminMobileNav.classList.remove('active');
            if (adminMobileOverlay) adminMobileOverlay.classList.remove('active');
            document.body.classList.remove('admin-menu-open');
            document.body.style.top = '';
            window.scrollTo(0, savedScrollY);
        }

        function toggleAdminMenu() {
            if (adminMobileNav.classList.contains('active')) {
                closeAdminMenu();
            } else {
                openAdminMenu();
            }
        }

        adminMobileMenuBtn.addEventListener('click', toggleAdminMenu);
        if (adminMobileOverlay) {
            adminMobileOverlay.addEventListener('click', closeAdminMenu);
        }

        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') closeAdminMenu();
        });

        window.addEventListener('resize', function() {
            if (window.innerWidth > 1024) closeAdminMenu();
        });
    }

    // Run immediately since DOM elements above are already parsed
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initAdminMobileMenu);
    } else {
        initAdminMobileMenu();
    }
})();
</script>
