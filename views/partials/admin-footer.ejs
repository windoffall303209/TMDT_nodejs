        <div class="admin-footer__meta">
            <span>Storefront nội bộ</span>
            <span>Thiết kế đồng bộ cùng user UI</span>
        </div>
    </div>
</footer>
<% } %>

<script src="/js/toast.js"></script>
<script src="/js/admin/admin-shell.js"></script>
<% extraAdminPageScripts.forEach((src) => { %>
