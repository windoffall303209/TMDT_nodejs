<%# Template EJS render xác thực đăng ký cho storefront hoặc tài khoản người dùng. %>
<%- include('../partials/header') %>

<!-- ===== Trang đăng ký tài khoản ===== -->
<div class="auth-page">
    <div class="container">
        <div class="auth-shell">
            <div class="auth-visual">
                <p class="auth-visual__eyebrow">Tạo tài khoản</p>
                <h2 class="auth-visual__title">Tạo tài khoản để lưu thông tin mua sắm.</h2>
                <p class="auth-visual__copy">Lưu địa chỉ, nhận ưu đãi và thanh toán nhanh hơn ở những lần mua tiếp theo.</p>
                <ul class="auth-visual__highlights">
                    <li>Lưu sản phẩm và thông tin mua sắm</li>
                    <li>Thanh toán nhanh hơn ở những lần mua sau</li>
                    <li>Nhận ưu đãi và thông báo bộ sưu tập mới</li>
                </ul>
            </div>

            <div class="auth-container">
                <h1>Tạo tài khoản</h1>
                <p class="auth-container__copy">Nhập thông tin cơ bản để bắt đầu mua sắm.</p>

                <% if (error) { %>
                    <div class="alert alert-error"><%= error %></div>
                    <% if (loginEmail) { %>
                        <div class="auth-inline-action">
                            <a href="/auth/login?email=<%= encodeURIComponent(loginEmail) %>">Đăng nhập để tiếp tục xác thực</a>
                        </div>
                    <% } %>
                <% } %>
                <form action="/auth/register" method="POST" class="auth-form" id="registerForm">
                    <div class="auth-form__row">
                        <div class="form-group">
                            <label for="full_name">Họ và tên *</label>
                            <input type="text" id="full_name" name="full_name" value="<%= formData.full_name || '' %>" required minlength="2" maxlength="100" placeholder="Họ và tên *">
                            <div class="field-error" id="full_name_error"></div>
                        </div>
                        <div class="form-group">
                            <label for="phone">Số điện thoại</label>
                            <input type="tel" id="phone" name="phone" value="<%= formData.phone || '' %>" maxlength="10" placeholder="Số điện thoại">
                            <div class="field-error" id="phone_error"></div>
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="email">Email *</label>
                        <input type="email" id="email" name="email" value="<%= formData.email || '' %>" required maxlength="255" placeholder="Email *">
                        <div class="field-error" id="email_error"></div>
                    </div>
                    <div class="form-group">
                        <label for="password">Mật khẩu *</label>
                        <div class="password-field">
                            <input type="password" id="password" name="password" required minlength="6" maxlength="50" placeholder="Mật khẩu *">
                            <button type="button" class="password-toggle" data-password-target="password">
                                <img class="eye-open" src="https://res.cloudinary.com/drs7xrtxo/image/upload/v1777038652/istockphoto-1481681927-612x612_n4gfaw.jpg" alt="" aria-hidden="true">
                                <img class="eye-closed" src="https://res.cloudinary.com/drs7xrtxo/image/upload/v1777038652/istockphoto-1481681933-612x612_pywojy.jpg" alt="" aria-hidden="true" hidden>
                            </button>
                        </div>
                        <div class="field-error" id="password_error"></div>
                    </div>

                    <div class="form-group">
                        <label for="confirm_password">Xác nhận mật khẩu *</label>
                        <div class="password-field">
                            <input type="password" id="confirm_password" name="confirm_password" required minlength="6" maxlength="50" placeholder="Xác nhận mật khẩu *">
                            <button type="button" class="password-toggle" data-password-target="confirm_password">
                                <img class="eye-open" src="https://res.cloudinary.com/drs7xrtxo/image/upload/v1777038652/istockphoto-1481681927-612x612_n4gfaw.jpg" alt="" aria-hidden="true">
                                <img class="eye-closed" src="https://res.cloudinary.com/drs7xrtxo/image/upload/v1777038652/istockphoto-1481681933-612x612_pywojy.jpg" alt="" aria-hidden="true" hidden>
                            </button>
                        </div>
                        <div class="password-match" id="passwordMatch"></div>
                        <div class="field-error" id="confirm_password_error"></div>
                    </div>

                    <!-- <div class="form-check">
                        <input type="checkbox" id="marketing_consent" name="marketing_consent">
                        <label for="marketing_consent">Tôi muốn nhận email khuyến mại và tin bộ sưu tập mới</label>
                    </div> -->

                    <button type="submit" class="btn btn-primary btn-block">Đăng ký tài khoản</button>
                </form>
                    <div class="auth-divider">
                        <span>hoặc</span>
                    </div>
                    <a href="/auth/google" class="auth-google-btn">
                        <img src="https://developers.google.com/identity/images/g-logo.png" 
                            alt="Google" width="18" height="18">
                        <span>Tiếp tục với Google</span>
                    </a>
                <div class="auth-footer">
                    <p>Đã có tài khoản? <a href="/auth/login">Đăng nhập</a></p>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="/js/register.js"></script>

<%- include('../partials/footer') %>
