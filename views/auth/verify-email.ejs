<%# Template EJS render xác thực email cho storefront hoặc tài khoản người dùng. %>
<%- include('../partials/header', { pageStyles: ['/css/auth/verify-email.css'] }) %>

<!-- ===== Trang xác thực email bằng mã OTP ===== -->
<div class="auth-page verify-email-page" data-code-sent="<%= codeSent ? 'true' : 'false' %>" data-redirect="<%= typeof redirect !== 'undefined' ? redirect : '' %>">
    <div class="container">
        <div class="auth-container verify-email-shell">
            <div class="verify-email-head">
                <p class="verify-email-head__eyebrow">Bảo Mật Tài Khoản</p>
                <h1>Xác Nhận Email</h1>
                <p class="verify-email-head__copy">Nhận mã OTP 6 số qua email để hoàn tất xác thực tài khoản.</p>
            </div>

            <div class="verify-email-recipient">
                <span class="verify-email-recipient__label">Mã sẽ được gửi đến</span>
                <strong class="verify-email-recipient__value"><%= user.email %></strong>
            </div>

            <div id="alert-container" class="verify-email-alerts">
                <% if (error) { %>
                    <div class="alert alert-error"><%= error %></div>
                <% } %>
                <% if (success) { %>
                    <div class="alert alert-success"><%= success %></div>
                <% } %>
            </div>

            <div id="step-send" class="verify-panel verify-panel--send" <%= codeSent ? 'hidden' : '' %>>
                <p class="verify-panel__copy">Nhấn nút bên dưới để nhận mã xác nhận qua email.</p>
                <button type="button" id="btn-send-code" class="btn btn-primary btn-block">
                    Gửi Mã Xác Nhận
                </button>
            </div>

            <div id="step-verify" class="verify-panel verify-panel--verify" <%= codeSent ? '' : 'hidden' %>>
                <div class="verify-panel__header">
                    <h2>Nhập Mã Xác Nhận</h2>
                    <p>Nhập đủ 6 số đã gửi đến email của bạn. Mã có hiệu lực trong 10 phút.</p>
                </div>
                <form id="verify-form" class="verify-code-form">
                    <div class="code-inputs" aria-label="Nhập mã xác nhận 6 số">
                        <input type="text" maxlength="1" class="code-input" data-index="0" inputmode="numeric" pattern="[0-9]*" aria-label="Số 1" autofocus>
                        <input type="text" maxlength="1" class="code-input" data-index="1" inputmode="numeric" pattern="[0-9]*" aria-label="Số 2">
                        <input type="text" maxlength="1" class="code-input" data-index="2" inputmode="numeric" pattern="[0-9]*" aria-label="Số 3">
                        <input type="text" maxlength="1" class="code-input" data-index="3" inputmode="numeric" pattern="[0-9]*" aria-label="Số 4">
                        <input type="text" maxlength="1" class="code-input" data-index="4" inputmode="numeric" pattern="[0-9]*" aria-label="Số 5">
                        <input type="text" maxlength="1" class="code-input" data-index="5" inputmode="numeric" pattern="[0-9]*" aria-label="Số 6">
                    </div>
                    <input type="hidden" id="full-code" name="code">

                    <button type="submit" id="btn-verify" class="btn btn-primary btn-block">
                        Xác Nhận
                    </button>
                </form>

                <div class="resend-section">
                    <p class="resend-section__copy">Không nhận được mã? <button type="button" id="btn-resend" class="btn-link">Gửi Lại</button></p>
                    <p class="timer-text" id="timer-text"></p>
                </div>
            </div>

            <div class="auth-footer verify-email-footer">
                <a href="/auth/login">Quay lại đăng nhập</a>
            </div>
        </div>
    </div>
</div>

<script src="/js/verify-email.js"></script>

<%- include('../partials/footer') %>
