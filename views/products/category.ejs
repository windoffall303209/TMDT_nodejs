<%- include('../partials/header') %>

<link rel="stylesheet" href="/css/product-list.css">

<div class="catalog-page page-shell">
    <div class="container">
        <section class="page-intro page-intro--compact catalog-intro catalog-intro--compact">
            <div class="catalog-intro__content">
                <h1 class="page-intro__title page-intro__title-inline">
                    <span>Danh mục</span>
                    <span class="page-intro__slash">/</span>
                    <span><%= category ? category.name : 'Sản phẩm' %></span>
                </h1>
            </div>
        </section>

        <div class="catalog-shortcuts">
            <a href="/products/category/nam" class="<%= category && category.slug === 'nam' ? 'active' : '' %>">Nam</a>
            <a href="/products/category/nu" class="<%= category && category.slug === 'nu' ? 'active' : '' %>">Nữ</a>
            <a href="/products/category/tre-em" class="<%= category && category.slug === 'tre-em' ? 'active' : '' %>">Trẻ em</a>
            <a href="/products?sale=true">Sale</a>
        </div>

        <section class="catalog-toolbar">
            <div class="products-filters__left">
                <button class="filter-btn active" data-filter="all">Tất cả</button>
                <button class="filter-btn" data-filter="new">Mới nhất</button>
                <button class="filter-btn" data-filter="bestseller">Bán chạy</button>
                <button class="filter-btn" data-filter="sale">Đang sale</button>
            </div>

            <div class="products-filters__sort">
                <label for="sortProducts">Sắp xếp</label>
                <select id="sortProducts">
                    <option value="newest" <%= currentSort === 'newest' ? 'selected' : '' %>>Mới nhất</option>
                    <option value="price-asc" <%= currentSort === 'price-asc' ? 'selected' : '' %>>Giá tăng dần</option>
                    <option value="price-desc" <%= currentSort === 'price-desc' ? 'selected' : '' %>>Giá giảm dần</option>
                    <option value="name-asc" <%= currentSort === 'name-asc' ? 'selected' : '' %>>Tên A-Z</option>
                    <option value="name-desc" <%= currentSort === 'name-desc' ? 'selected' : '' %>>Tên Z-A</option>
                </select>
            </div>
        </section>

        <% if (products && products.length > 0) { %>
            <div class="products-grid catalog-grid" id="productsGrid">
                <% products.forEach(product => { %>
                    <%- include('../partials/product-card', { product }) %>
                <% }) %>
            </div>
        <% } else { %>
            <div class="empty-panel">
                <h3>Danh mục này tạm thời chưa có hàng</h3>
                <p>Hãy thử danh mục khác hoặc xem khu sale để tiếp tục mua sắm.</p>
                <a href="/products" class="btn btn-primary">Quay lại trang sản phẩm</a>
            </div>
        <% } %>
    </div>
</div>

<script src="/js/category.js"></script>

<%- include('../partials/footer') %>
