<%- include('../partials/header') %>

<link rel="stylesheet" href="/css/product-list.css">

<%
    const currentCategory = typeof category !== 'undefined' ? category : null;
    const pageTitle = currentCategory
        ? currentCategory.name
        : (typeof query !== 'undefined' && query
            ? `Kết quả tìm kiếm: "${query}"`
            : ((typeof isSalePage !== 'undefined' && isSalePage) ? 'Sản phẩm đang giảm giá' : 'Tất cả sản phẩm'));
    const pageEyebrow = currentCategory
        ? 'Danh mục'
        : ((typeof isSalePage !== 'undefined' && isSalePage) ? 'Ưu đãi' : 'Sản phẩm');
%>

<div class="catalog-page page-shell">
    <div class="container">
        <section class="page-intro page-intro--compact catalog-intro catalog-intro--compact">
            <div class="catalog-intro__content">
                <h1 class="page-intro__title page-intro__title-inline">
                    <span><%= pageEyebrow %></span>
                    <span class="page-intro__slash">/</span>
                    <span><%= pageTitle %></span>
                </h1>
            </div>
        </section>

        <div class="catalog-shortcuts">
            <a href="/products/category/nam">Nam</a>
            <a href="/products/category/nu">Nữ</a>
            <a href="/products/category/tre-em">Trẻ em</a>
            <a href="/products?sale=true">Sale</a>
        </div>

        <%- include('../partials/catalog-toolbar', {
            paginationPath,
            paginationQuery,
            totalItems,
            perPage,
            perPageOptions,
            currentSort,
            resultsLabel: 'sản phẩm'
        }) %>

        <% if (products && products.length > 0) { %>
            <div class="products-grid catalog-grid" id="productsGrid">
                <% products.forEach((product) => { %>
                    <%- include('../partials/product-card', { product }) %>
                <% }) %>
            </div>
        <% } else { %>
            <div class="empty-panel">
                <h3>Chưa tìm thấy sản phẩm phù hợp</h3>
                <p>Thử đổi từ khóa, chuyển danh mục hoặc mở khu sale để tiếp tục mua sắm.</p>
                <a href="/products" class="btn btn-primary">Xem lại toàn bộ sản phẩm</a>
            </div>
        <% } %>

        <%- include('../partials/catalog-pagination', {
            paginationPath,
            paginationQuery,
            currentPage,
            totalPages,
            perPage
        }) %>
    </div>
</div>

<script src="/js/catalog-controls.js"></script>
<%- include('../partials/footer') %>
