<%# Template EJS render sản phẩm tìm kiếm kết quả cho storefront hoặc tài khoản người dùng. %>
<%- include('../partials/header') %>

<link rel="stylesheet" href="/css/product-list.css">

<%
    // Chuẩn bị số cột grid cho trang kết quả tìm kiếm
    const storefrontConfig = storefrontSettings || {};
    const productGridColumns = Math.min(6, Math.max(2, Number.parseInt(storefrontConfig.product_grid_columns, 10) || 5));
    const productGridColumnsLg = Math.min(productGridColumns, 4);
    const productGridColumnsMd = Math.min(productGridColumns, 3);
%>

<!-- ===== Trang kết quả tìm kiếm sản phẩm ===== -->
<div class="catalog-page page-shell">
    <div
        class="container"
        data-catalog-container
        data-catalog-columns="<%= productGridColumns %>"
        data-catalog-columns-lg="<%= productGridColumnsLg %>"
        data-catalog-columns-md="<%= productGridColumnsMd %>"
    >
        <section class="page-intro page-intro--compact catalog-intro catalog-intro--compact catalog-intro--search">
            <div class="catalog-intro__content">
                <h1 class="page-intro__title page-intro__title-inline">
                    <span>Tìm kiếm</span>
                    <span class="page-intro__slash">/</span>
                    <span>Kết quả cho "<%= query %>"</span>
                </h1>
            </div>
            <p class="catalog-intro__meta"><%= typeof totalItems !== 'undefined' ? totalItems : (products ? products.length : 0) %> sản phẩm</p>
        </section>

        <div class="catalog-layout">
            <%- include('../partials/catalog-sidebar', {
                category,
                categories,
                currentSort,
                filters,
                filterPriceRanges,
                filterRatingOptions,
                paginationPath,
                perPage,
                query,
                totalItems
            }) %>

            <div class="catalog-results">
                <%- include('../partials/catalog-toolbar', {
                    paginationPath,
                    paginationQuery,
                    totalItems,
                    perPage,
                    perPageOptions,
                    currentSort,
                    resultsLabel: 'kết quả phù hợp'
                }) %>

                <% if (products && products.length > 0) { %>
                    <div class="products-grid catalog-grid">
                        <% products.forEach((product) => { %>
                            <%- include('../partials/product-card', { product }) %>
                        <% }) %>
                    </div>
                <% } else { %>
                    <div class="empty-panel search-empty">
                        <h3>Không tìm thấy sản phẩm phù hợp</h3>
                        <p>Thử tìm bằng từ khóa ngắn hơn hoặc đi đến các danh mục mua nhanh bên dưới.</p>
                        <div class="search-empty__actions">
                            <a href="/products/category/nam" class="btn btn-secondary">Xem danh mục nam</a>
                            <a href="/products/category/nu" class="btn btn-secondary">Xem danh mục nữ</a>
                            <a href="/products" class="btn btn-primary">Xem tất cả sản phẩm</a>
                        </div>
                    </div>
                <% } %>

                <%- include('../partials/catalog-pagination', {
                    paginationPath,
                    paginationQuery,
                    currentPage,
                    totalPages,
                    perPage
                }) %>
            </div>
        </div>
    </div>
</div>

<script src="/js/catalog-controls.js"></script>
<%- include('../partials/footer') %>
