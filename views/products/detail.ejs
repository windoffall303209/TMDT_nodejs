<%# Template EJS render sản phẩm chi tiết cho storefront hoặc tài khoản người dùng. %>
<%- include('../partials/header') %>

<link rel="stylesheet" href="/css/product-detail.css">

<%
    // Chuẩn bị dữ liệu hiển thị chi tiết: ảnh chính, biến thể, trạng thái review
    let mainImage = product.primary_image;
    if (!mainImage && product.images && product.images.length > 0) {
        mainImage = product.images[0].image_url;
    }

    const colors = product.variants ? [...new Set(product.variants.filter(variant => variant.color).map(variant => variant.color))] : [];
    const sizes = product.variants ? [...new Set(product.variants.filter(variant => variant.size).map(variant => variant.size))] : [];
    const existingReview = reviewContext && reviewContext.existingReview ? reviewContext.existingReview : null;
    const canCreateReview = Boolean(reviewContext && reviewContext.canReview);
    const canEditReview = Boolean(existingReview);
    const reviewFormAction = canEditReview
        ? `/products/${product.slug}/reviews/${existingReview.id}/edit`
        : `/products/${product.slug}/reviews`;
    const reviewFormHeading = canEditReview ? 'Chỉnh sửa review của bạn' : 'Viết review của bạn';
    const reviewSubmitLabel = canEditReview ? 'Cập nhật đánh giá' : 'Gửi đánh giá';
    const reviewOrderCode = canEditReview
        ? existingReview.order_code
        : (reviewContext && reviewContext.eligibleOrder ? reviewContext.eligibleOrder.order_code : null);
    const reviewFormErrorCodes = ['invalid-rating', 'invalid-media', 'file-too-large', 'upload-failed', 'failed'];
    const viewOwnReviewOpen = Boolean(canEditReview && reviewFeedbackCode && reviewFeedbackCode !== 'updated');
    const editOwnReviewOpen = Boolean(canEditReview && reviewFormErrorCodes.includes(reviewFeedbackCode));
    const createReviewPanelOpen = Boolean(canCreateReview && reviewFormErrorCodes.includes(reviewFeedbackCode));
    const reviewBodyOpen = Boolean(reviewFeedback || viewOwnReviewOpen || editOwnReviewOpen || createReviewPanelOpen);
    const averageRating = Number(product.average_rating || 0);
    const reviewCount = Number(product.review_count || 0);
    const soldCount = Math.max(0, Number.parseInt(product.sold_count, 10) || 0);
    const highlightedStars = Math.max(0, Math.min(5, Math.round(averageRating)));
    const formatSoldCount = (value) => {
        if (value >= 1000000) {
            return `${(value / 1000000).toFixed(value % 1000000 === 0 ? 0 : 1)}M`;
        }

        if (value >= 1000) {
            return `${(value / 1000).toFixed(value % 1000 === 0 ? 0 : 1)}k`;
        }

        return value.toLocaleString('vi-VN');
    };
%>

<!-- ===== Trang chi tiết sản phẩm ===== -->
<div class="product-detail-page page-shell">
    <div class="container">
        <div class="product-breadcrumb">
            <a href="/">Trang chủ</a>
            <span>/</span>
            <% if (product.category_name) { %>
                <a href="/products/category/<%= product.category_slug %>"><%= product.category_name %></a>
                <span>/</span>
            <% } %>
            <span><%= product.name %></span>
        </div>

        <!-- Khối chính: gallery bên trái + thông tin mua hàng bên phải -->
        <div class="product-detail-grid">
            <div class="product-gallery">
                <% if (product.images && product.images.length > 1) { %>
                    <div class="product-gallery__thumbs">
                        <% product.images.forEach((img, index) => { %>
                            <img
                                src="<%= img.image_url %>"
                                alt="<%= product.name %> - <%= index + 1 %>"
                                class="product-gallery__thumb <%= index === 0 ? 'product-gallery__thumb--active' : '' %>"
                                data-index="<%= index %>"
                                data-image-url="<%= img.image_url %>"
                                loading="lazy"
                                decoding="async"
                            >
                        <% }) %>
                    </div>
                <% } %>

                <div class="product-gallery__main">
                    <% if (mainImage) { %>
                        <img
                            src="<%= mainImage %>"
                            alt="<%= product.name %>"
                            class="product-gallery__main-image"
                            id="mainImage"
                        >
                        <div id="fallbackIcon" class="product-gallery__fallback" hidden>
                            <span class="product-gallery__fallback-icon">WF</span>
                        </div>
                    <% } else { %>
                        <div class="product-gallery__placeholder">
                            <span class="product-gallery__placeholder-icon">WF</span>
                        </div>
                    <% } %>

                    <% if (product.images && product.images.length > 1) { %>
                        <button type="button" data-gallery-nav="prev" class="product-gallery__nav-btn product-gallery__nav-btn--prev" aria-label="Ảnh trước">&#8249;</button>
                        <button type="button" data-gallery-nav="next" class="product-gallery__nav-btn product-gallery__nav-btn--next" aria-label="Ảnh sau">&#8250;</button>
                        <div class="product-gallery__counter">
                            <span id="currentIndex">1</span> / <%= product.images.length %>
                        </div>
                    <% } %>
                </div>
            </div>

            <div class="product-info">
               <h1 class="product-info__title"><%= product.name %></h1>
                <% if (product.sku) { %>
                    <p class="product-info__sku">SKU: <span><%= product.sku %></span></p>
                <% } %>

                <div class="product-info__meta">
                    <button type="button" class="product-info__rating-link" data-scroll-to-reviews>
                        <span class="product-info__rating-stars" aria-hidden="true">
                            <% [1, 2, 3, 4, 5].forEach((starIndex) => { %>
                                <span class="product-info__rating-star <%= starIndex <= highlightedStars ? 'is-active' : '' %>">★</span>
                            <% }) %>
                        </span>
                        <span class="product-info__rating-value"><%= averageRating > 0 ? averageRating.toFixed(1) : '0.0' %></span>
                        <span class="product-info__rating-count">(<%= reviewCount.toLocaleString('vi-VN') %> đánh giá)</span>
                    </button>
                    <span class="product-info__meta-divider" aria-hidden="true">|</span>
                    <span class="product-info__sold-count"><%= formatSoldCount(soldCount) %> đã bán</span>
                </div>

                <div class="product-info__price-box">
                    <% if (product.price !== product.final_price && product.final_price) { %>
                        <p class="product-info__price-current" id="productPrice"><%= product.final_price.toLocaleString('vi-VN') %>đ</p>
                        <p class="product-info__price-original"><%= product.price.toLocaleString('vi-VN') %>đ</p>
                        <span class="product-info__discount-badge">Giảm <%= Math.round((1 - product.final_price / product.price) * 100) %>%</span>
                    <% } else { %>
                        <p class="product-info__price-current" id="productPrice"><%= (product.final_price || product.price).toLocaleString('vi-VN') %>đ</p>
                    <% } %>
                </div>

                <% if (product.variants && product.variants.length > 0) { %>
                    <div class="variant-selector">
                        <% if (colors.length > 0) { %>
                            <div class="variant-group">
                                <label>Màu sắc</label>
                                <div class="variant-options" id="colorOptions">
                                    <% colors.forEach(color => { %>
                                        <button type="button" class="variant-btn color-btn" data-color="<%= color %>"><%= color %></button>
                                    <% }) %>
                                </div>
                            </div>
                        <% } %>

                        <% if (sizes.length > 0) { %>
                            <div class="variant-group">
                                <label>Kích thước</label>
                                <div class="variant-options" id="sizeOptions">
                                    <% sizes.forEach(size => { %>
                                        <button type="button" class="variant-btn size-btn" data-size="<%= size %>"><%= size %></button>
                                    <% }) %>
                                </div>
                            </div>
                        <% } %>
                    </div>
                <% } %>

                <p class="variant-stock" id="variantStock" aria-live="polite"></p>

                <div class="product-info__quantity">
                    <label>Số lượng</label>
                    <div class="quantity-selector">
                        <button type="button" class="quantity-selector__btn" id="qtyMinus" aria-label="Giảm">−</button>
                        <input type="number" class="quantity-selector__input" id="productQty" value="1" min="1" inputmode="numeric">
                        <button type="button" class="quantity-selector__btn" id="qtyPlus" aria-label="Tăng">+</button>
                    </div>
                </div>

                <div class="product-info__actions">
                    <button class="btn product-info__action-btn product-info__action-btn--cart" data-product-action="add-to-cart">Thêm vào giỏ hàng</button>
                    <button class="btn btn-accent product-info__action-btn product-info__action-btn--buy" data-product-action="buy-now">Mua ngay</button>
                </div>
            </div>
        </div>

        <% if (product.description) { %>
            <section class="product-description-section">
                <button type="button" class="product-description__toggle" id="descToggle" aria-expanded="false">
                    <h3>Mô tả sản phẩm</h3>
                    <span class="product-description__toggle-icon" id="descToggleIcon">▼</span>
                </button>
                <div class="product-description__body" id="descBody">
                    <div class="product-description-content">
                        <%- product.descriptionHtml %>
                    </div>
                </div>
            </section>
        <% } %>

        <!-- Khu vực đánh giá: thông báo, form tạo/sửa, danh sách review -->
        <section class="product-reviews" id="productReviewsSection">
            <button
                type="button"
                class="product-reviews__toggle <%= reviewBodyOpen ? 'is-open' : '' %>"
                id="reviewToggle"
                aria-expanded="<%= reviewBodyOpen ? 'true' : 'false' %>"
            >
                <div class="product-reviews__toggle-copy">
                    <h2 class="product-reviews__title">Đánh giá sản phẩm</h2>
                    <p class="product-reviews__subtitle">Chia sẻ cảm nhận thực tế của bạn sau khi nhận hàng.</p>
                </div>
                <span class="product-reviews__toggle-icon">▼</span>
            </button>

            <div class="product-reviews__body <%= reviewBodyOpen ? 'is-open' : '' %>" id="reviewBody" data-toggle-mode="display">
                <% if (reviewFeedback) { %>
                    <div class="product-reviews__notice product-reviews__notice--<%= reviewFeedback.type %>">
                        <%= reviewFeedback.message %>
                    </div>
                <% } %>

                <% if (canCreateReview || canEditReview) { %>
                <div class="product-review-compose">
                    <% if (canCreateReview) { %>
                        <div class="product-review-state product-review-state--mine">
                            <div class="product-review-state__top">
                                <div>
                                    <strong>Bạn chưa đánh giá sản phẩm này</strong>
                                    <p>Hãy chia sẻ trải nghiệm thực tế của bạn sau khi nhận hàng.</p>
                                </div>
                                <button
                                    type="button"
                                    class="product-review-state__toggle-btn <%= createReviewPanelOpen ? 'is-open' : '' %>"
                                    id="createReviewToggle"
                                    aria-expanded="<%= createReviewPanelOpen ? 'true' : 'false' %>"
                                    data-open-label="Đánh giá ngay"
                                    data-close-label="Đóng form đánh giá"
                                >
                                    <%= createReviewPanelOpen ? 'Đóng form đánh giá' : 'Đánh giá ngay' %>
                                </button>
                            </div>

                            <div class="product-review-state__panel <%= createReviewPanelOpen ? 'is-open' : '' %>" id="createReviewPanel" data-toggle-mode="display">
                                <form action="<%= reviewFormAction %>" method="POST" enctype="multipart/form-data" class="product-review-form product-review-form--edit">
                                    <div class="product-review-form__header">
                                        <div>
                                            <strong><%= reviewFormHeading %></strong>
                                            <% if (reviewOrderCode) { %>
                                                <span>Từ đơn <%= reviewOrderCode %></span>
                                            <% } %>
                                        </div>
                                    </div>

                                    <div class="product-review-form__field">
                                        <span class="product-review-form__label">Số sao</span>
                                        <div class="product-review-form__rating">
                                            <% [1, 2, 3, 4, 5].forEach((ratingValue) => { %>
                                                <label class="product-review-form__rating-option">
                                                    <input type="radio" name="rating" value="<%= ratingValue %>" <%= ratingValue === 5 ? 'checked' : '' %>>
                                                    <span><%= ratingValue %>★</span>
                                                </label>
                                            <% }) %>
                                        </div>
                                    </div>

                                    <div class="product-review-form__field">
                                        <label for="reviewComment" class="product-review-form__label">Nội dung</label>
                                        <textarea
                                            id="reviewComment"
                                            name="comment"
                                            class="product-review-form__textarea"
                                            rows="4"
                                            maxlength="2000"
                                            placeholder="Sản phẩm có đúng như mong đợi không? Chất liệu, form, kích thước ra sao?"
                                        ></textarea>
                                    </div>

                                    <div class="product-review-form__field">
                                        <label for="reviewMediaInput" class="product-review-form__label">Ảnh hoặc video</label>
                                        <input
                                            id="reviewMediaInput"
                                            type="file"
                                            name="reviewMedia"
                                            class="product-review-form__file-input"
                                            accept="image/jpeg,image/png,image/gif,image/webp,video/mp4,video/webm,video/quicktime"
                                            multiple
                                        >
                                        <p class="product-review-form__help" id="reviewMediaMeta">Tối đa 5 ảnh và 1 video cho mỗi review.</p>
                                        <div class="product-review-form__media-preview" id="reviewMediaPreview"></div>
                                    </div>

                                    <button type="submit" class="btn btn-accent product-review-form__submit"><%= reviewSubmitLabel %></button>
                                </form>
                            </div>
                        </div>
                    <% } else if (canEditReview) { %>
                            <div class="product-review-state product-review-state--mine">
                                <div class="product-review-state__top">
                                    <div>
                                        <strong>Bạn đã đánh giá sản phẩm này</strong>
                                        <% if (reviewOrderCode) { %>
                                            <p>Từ đơn <%= reviewOrderCode %>.</p>
                                        <% } %>
                                    </div>
                                    <button
                                        type="button"
                                        class="product-review-state__toggle-btn <%= viewOwnReviewOpen ? 'is-open' : '' %>"
                                        id="myReviewToggle"
                                        aria-expanded="<%= viewOwnReviewOpen ? 'true' : 'false' %>"
                                        data-open-label="Xem đánh giá của bạn"
                                        data-close-label="Ẩn đánh giá của bạn"
                                    >
                                        <%= viewOwnReviewOpen ? 'Ẩn đánh giá của bạn' : 'Xem đánh giá của bạn' %>
                                    </button>
                                </div>

                                <div class="product-review-state__panel <%= viewOwnReviewOpen ? 'is-open' : '' %>" id="myReviewPanel" data-toggle-mode="display">
                                    <div class="product-review-state__summary">
                                        <div class="product-review-item__header">
                                            <div class="product-review-item__identity">
                                                <span class="product-review-item__avatar">
                                                    <% if (user.avatar_url) { %>
                                                        <img src="<%= user.avatar_url %>" alt="<%= user.full_name || 'Bạn' %>">
                                                    <% } else { %>
                                                        <%= (user.full_name || 'B').trim().charAt(0).toUpperCase() %>
                                                    <% } %>
                                                </span>
                                                <span class="product-review-item__author"><%= user.full_name || 'Bạn' %></span>
                                            </div>
                                            <span class="product-review-item__date"><%= new Date(existingReview.created_at).toLocaleDateString('vi-VN') %></span>
                                        </div>
                                        <div class="product-review-item__stars"><%= '★'.repeat(existingReview.rating) %><%= '☆'.repeat(5 - existingReview.rating) %></div>
                                        <% if (existingReview.comment) { %>
                                            <p class="product-review-item__text"><%= existingReview.comment %></p>
                                        <% } %>
                                        <% if (existingReview.media && existingReview.media.length > 0) { %>
                                            <div class="product-review-item__media">
                                                <% existingReview.media.forEach((mediaItem) => { %>
                                                    <div class="product-review-item__media-card">
                                                        <% if (mediaItem.media_type === 'video') { %>
                                                            <video controls preload="metadata" class="product-review-item__video">
                                                                <source src="<%= mediaItem.media_url %>">
                                                            </video>
                                                        <% } else { %>
                                                            <img
                                                                src="<%= mediaItem.media_url %>"
                                                                alt="Review media"
                                                                class="product-review-item__image"
                                                                loading="lazy"
                                                                decoding="async"
                                                            >
                                                        <% } %>
                                                    </div>
                                                <% }) %>
                                            </div>
                                        <% } %>
                                    </div>

                                    <div class="product-review-state__actions">
                                        <button
                                            type="button"
                                            class="product-review-state__secondary-btn <%= editOwnReviewOpen ? 'is-open' : '' %>"
                                            id="reviewEditToggle"
                                            aria-expanded="<%= editOwnReviewOpen ? 'true' : 'false' %>"
                                            data-open-label="Chỉnh sửa đánh giá"
                                            data-close-label="Đóng chỉnh sửa"
                                        >
                                            <%= editOwnReviewOpen ? 'Đóng chỉnh sửa' : 'Chỉnh sửa đánh giá' %>
                                        </button>
                                    </div>

                                    <div class="product-review-state__edit <%= editOwnReviewOpen ? 'is-open' : '' %>" id="reviewEditPanel" data-toggle-mode="display">
                                        <form action="<%= reviewFormAction %>" method="POST" enctype="multipart/form-data" class="product-review-form product-review-form--edit">
                                            <div class="product-review-form__header">
                                                <div>
                                                    <strong><%= reviewFormHeading %></strong>
                                                    <% if (reviewOrderCode) { %>
                                                        <span>Từ đơn <%= reviewOrderCode %></span>
                                                    <% } %>
                                                </div>
                                                <p class="product-review-form__hint">
                                                    Bạn có thể sửa nội dung, thêm media mới hoặc bỏ bớt media cũ.
                                                </p>
                                            </div>

                                            <div class="product-review-form__field">
                                                <span class="product-review-form__label">Số sao</span>
                                                <div class="product-review-form__rating">
                                                    <% [1, 2, 3, 4, 5].forEach((ratingValue) => { %>
                                                        <label class="product-review-form__rating-option">
                                                            <input
                                                                type="radio"
                                                                name="rating"
                                                                value="<%= ratingValue %>"
                                                                <%= existingReview.rating === ratingValue ? 'checked' : '' %>
                                                            >
                                                            <span><%= ratingValue %>★</span>
                                                        </label>
                                                    <% }) %>
                                                </div>
                                            </div>

                                            <div class="product-review-form__field">
                                                <label for="reviewComment" class="product-review-form__label">Nội dung</label>
                                                <textarea
                                                    id="reviewComment"
                                                    name="comment"
                                                    class="product-review-form__textarea"
                                                    rows="4"
                                                    maxlength="2000"
                                                    placeholder="Sản phẩm có đúng như mong đợi không? Chất liệu, form, kích thước ra sao?"
                                                ><%= existingReview.comment || '' %></textarea>
                                            </div>

                                            <div class="product-review-form__field">
                                                <label for="reviewMediaInput" class="product-review-form__label">Ảnh hoặc video</label>
                                                <input
                                                    id="reviewMediaInput"
                                                    type="file"
                                                    name="reviewMedia"
                                                    class="product-review-form__file-input"
                                                    accept="image/jpeg,image/png,image/gif,image/webp,video/mp4,video/webm,video/quicktime"
                                                    multiple
                                                >
                                                <p class="product-review-form__help" id="reviewMediaMeta">Tối đa 5 ảnh và 1 video cho mỗi review.</p>
                                                <div class="product-review-form__media-preview" id="reviewMediaPreview"></div>
                                            </div>

                                            <% if (existingReview.media && existingReview.media.length > 0) { %>
                                                <div class="product-review-form__field">
                                                    <span class="product-review-form__label">Media hiện tại</span>
                                                    <div class="product-review-current-media">
                                                        <% existingReview.media.forEach((mediaItem) => { %>
                                                            <label class="product-review-current-media__item">
                                                                <div class="product-review-current-media__frame">
                                                                    <% if (mediaItem.media_type === 'video') { %>
                                                                        <video controls preload="metadata" class="product-review-current-media__video">
                                                                            <source src="<%= mediaItem.media_url %>">
                                                                        </video>
                                                                    <% } else { %>
                                                                        <img
                                                                            src="<%= mediaItem.media_url %>"
                                                                            alt="Review media"
                                                                            class="product-review-current-media__image"
                                                                            loading="lazy"
                                                                            decoding="async"
                                                                        >
                                                                    <% } %>
                                                                </div>
                                                                <span class="product-review-current-media__checkbox">
                                                                    <input type="checkbox" name="remove_media_ids" value="<%= mediaItem.id %>">
                                                                    Bỏ media này
                                                                </span>
                                                            </label>
                                                        <% }) %>
                                                    </div>
                                                </div>
                                            <% } %>

                                            <button type="submit" class="btn btn-accent product-review-form__submit"><%= reviewSubmitLabel %></button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                    <% } %>
                </div>
                <% } %>

                <% if (reviews && reviews.length > 0) { %>
                    <div class="product-reviews__summary">
                        <div>
                            <div class="product-reviews__score"><%= averageRating.toFixed(1) %></div>
                            <div class="product-reviews__stars">★★★★★</div>
                            <div class="product-reviews__count"><%= reviewCount || reviews.length %> đánh giá</div>
                        </div>
                    </div>

                    <div class="product-reviews__list">
                        <% reviews.forEach(review => { %>
                            <div class="product-review-item">
                                <div class="product-review-item__header">
                                    <div class="product-review-item__identity">
                                        <span class="product-review-item__avatar">
                                            <% if (review.user_avatar) { %>
                                                <img src="<%= review.user_avatar %>" alt="<%= review.user_name || 'Người dùng' %>">
                                            <% } else { %>
                                                <%= (review.user_name || 'N').trim().charAt(0).toUpperCase() %>
                                            <% } %>
                                        </span>
                                        <span class="product-review-item__author"><%= review.user_name || 'Người dùng' %></span>
                                    </div>
                                    <span class="product-review-item__date"><%= new Date(review.created_at).toLocaleDateString('vi-VN') %></span>
                                </div>
                                <div class="product-review-item__stars"><%= '★'.repeat(review.rating) %><%= '☆'.repeat(5 - review.rating) %></div>
                                <% if (review.comment) { %>
                                    <p class="product-review-item__text"><%= review.comment %></p>
                                <% } %>
                                <% if (review.media && review.media.length > 0) { %>
                                    <div class="product-review-item__media">
                                        <% review.media.forEach((mediaItem) => { %>
                                            <div class="product-review-item__media-card">
                                                <% if (mediaItem.media_type === 'video') { %>
                                                    <video controls preload="metadata" class="product-review-item__video">
                                                        <source src="<%= mediaItem.media_url %>">
                                                    </video>
                                                <% } else { %>
                                                    <img
                                                        src="<%= mediaItem.media_url %>"
                                                        alt="Review media"
                                                        class="product-review-item__image"
                                                        loading="lazy"
                                                        decoding="async"
                                                    >
                                                <% } %>
                                            </div>
                                        <% }) %>
                                    </div>
                                <% } %>
                            </div>
                        <% }) %>
                    </div>
                <% } else { %>
                    <div class="product-reviews__empty">
                        Chưa có đánh giá nào. Hãy là người đầu tiên chia sẻ cảm nhận về sản phẩm này.
                    </div>
                <% } %>
            </div>
        </section>

        <!-- Sản phẩm liên quan cùng danh mục -->
        <% if (relatedProducts && relatedProducts.length > 0) { %>
            <section class="related-products">
                <div class="home-section__header">
                    <div>
                        <p class="section-kicker">Gợi ý thêm</p>
                        <h2 class="section-title">Sản phẩm liên quan</h2>
                    </div>
                    <a href="/products/category/<%= product.category_slug %>" class="home-section__link">Xem thêm cùng danh mục</a>
                </div>

                <div class="related-products__grid">
                    <% relatedProducts.slice(0, 4).forEach(relatedProduct => { %>
                        <%- include('../partials/product-card', { product: relatedProduct }) %>
                    <% }) %>
                </div>
            </section>
        <% } %>
    </div>
</div>

<%# Bootstrap dữ liệu JSON cho script phía client. %>
<script type="application/json" id="productDetailBootstrap"><%- JSON.stringify({
    productId: product.id,
    variants: product.variants || [],
    baseCurrentPrice: product.final_price || product.price,
    baseOriginalPrice: product.price || 0,
    hasDiscount: Boolean(product.price !== product.final_price && product.final_price),
    productStock: Number.parseInt(product.stock_quantity, 10) || 0,
    images: (product.images || []).map(img => img.image_url),
    initialImage: product.primary_image || ((product.images && product.images[0]) ? product.images[0].image_url : null)
}).replace(/</g, '\\u003c') %></script>
<script src="/js/product-detail.js"></script>

<%- include('../partials/footer') %>
