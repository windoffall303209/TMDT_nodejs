<%- include('../partials/header') %>

<!-- Load Product Detail CSS -->
<link rel="stylesheet" href="/css/product-detail.css">

<div class="product-detail-page">
    <div class="container">
        <div class="product-detail-grid">
            <!-- Product Images Gallery -->
            <div class="product-gallery">
                <!-- Main Image -->
                <div class="product-gallery__main">
                    <% 
                    let mainImage = product.primary_image;
                    if (!mainImage && product.images && product.images.length > 0) {
                        mainImage = product.images[0].image_url;
                    }
                    %>
                    <% if (mainImage) { %>
                        <img src="<%= mainImage %>" 
                             alt="<%= product.name %>" 
                             class="product-gallery__main-image"
                             id="mainImage"
                             onerror="this.style.display='none'; document.getElementById('fallbackIcon').style.display='flex';">
                        <div id="fallbackIcon" class="product-gallery__fallback">
                            <span class="product-gallery__fallback-icon">👕</span>
                        </div>
                    <% } else { %>
                        <div class="product-gallery__placeholder">
                            <span class="product-gallery__placeholder-icon">👕</span>
                        </div>
                    <% } %>
                    
                    <% if (product.images && product.images.length > 1) { %>
                        <!-- Navigation Arrows -->
                        <button onclick="prevImage()" class="product-gallery__nav-btn product-gallery__nav-btn--prev">❮</button>
                        <button onclick="nextImage()" class="product-gallery__nav-btn product-gallery__nav-btn--next">❯</button>
                        
                        <!-- Image Counter -->
                        <div class="product-gallery__counter">
                            <span id="currentIndex">1</span> / <%= product.images.length %>
                        </div>
                    <% } %>
                </div>
                
                <!-- Thumbnail Gallery -->
                <% if (product.images && product.images.length > 1) { %>
                    <div class="product-gallery__thumbs">
                        <% product.images.forEach((img, index) => { %>
                            <img src="<%= img.image_url %>" 
                                 alt="<%= product.name %> - <%= index + 1 %>"
                                 class="product-gallery__thumb <%= index === 0 ? 'product-gallery__thumb--active' : '' %>"
                                 data-index="<%= index %>"
                                 onclick="selectImage(<%= index %>, '<%= img.image_url %>')">
                        <% }) %>
                    </div>
                <% } %>
            </div>
            
            <!-- Product Info -->
            <div class="product-info">
                <h1 class="product-info__title"><%= product.name %></h1>
                
                <% if (product.category_name) { %>
                    <p class="product-info__category">
                        Danh mục: <a href="/products/category/<%= product.category_slug %>" class="product-info__category-link"><%= product.category_name %></a>
                    </p>
                <% } %>
                
                <div class="product-info__price-box">
                    <% if (product.price !== product.final_price && product.final_price) { %>
                        <p class="product-info__price-original">
                            <%= product.price.toLocaleString('vi-VN') %>đ
                        </p>
                        <p class="product-info__price-current" id="productPrice">
                            <%= product.final_price.toLocaleString('vi-VN') %>đ
                        </p>
                        <span class="product-info__discount-badge">
                            Giảm <%= Math.round((1 - product.final_price / product.price) * 100) %>%
                        </span>
                    <% } else { %>
                        <p class="product-info__price-current" id="productPrice">
                            <%= (product.final_price || product.price).toLocaleString('vi-VN') %>đ
                        </p>
                    <% } %>
                </div>

                <% if (product.variants && product.variants.length > 0) { %>
                    <div class="variant-selector" style="margin: 20px 0;">
                        <%
                            const colors = [...new Set(product.variants.filter(v => v.color).map(v => v.color))];
                            const sizes = [...new Set(product.variants.filter(v => v.size).map(v => v.size))];
                        %>

                        <% if (colors.length > 0) { %>
                        <div class="variant-group" style="margin-bottom: 15px;">
                            <label style="font-weight: 600; display: block; margin-bottom: 8px; color: #333;">Màu sắc:</label>
                            <div class="variant-options" id="colorOptions" style="display: flex; gap: 8px; flex-wrap: wrap;">
                                <% colors.forEach(color => { %>
                                    <button type="button" class="variant-btn color-btn" data-color="<%= color %>"
                                            onclick="selectColor(this, '<%= color %>')"
                                            style="padding: 8px 18px; border: 2px solid #ddd; border-radius: 6px; background: #fff; cursor: pointer; font-size: 14px; transition: all 0.2s;">
                                        <%= color %>
                                    </button>
                                <% }) %>
                            </div>
                        </div>
                        <% } %>

                        <% if (sizes.length > 0) { %>
                        <div class="variant-group" style="margin-bottom: 15px;">
                            <label style="font-weight: 600; display: block; margin-bottom: 8px; color: #333;">Kích thước:</label>
                            <div class="variant-options" id="sizeOptions" style="display: flex; gap: 8px; flex-wrap: wrap;">
                                <% sizes.forEach(size => { %>
                                    <button type="button" class="variant-btn size-btn" data-size="<%= size %>"
                                            onclick="selectSize(this, '<%= size %>')"
                                            style="padding: 8px 18px; border: 2px solid #ddd; border-radius: 6px; background: #fff; cursor: pointer; font-size: 14px; transition: all 0.2s;">
                                        <%= size %>
                                    </button>
                                <% }) %>
                            </div>
                        </div>
                        <% } %>

                        <div id="variantStock" style="margin-top: 10px; font-size: 14px; color: #666;"></div>
                    </div>

                    <script>
                        window.productVariants = <%- JSON.stringify(product.variants) %>;
                        window.productBasePrice = <%= product.final_price || product.price %>;
                    </script>
                <% } %>

                <% if (product.description) { %>
                    <div class="product-info__description">
                        <h3 class="product-info__description-title">Mô tả sản phẩm</h3>
                        <p class="product-info__description-text"><%= product.description %></p>
                    </div>
                <% } %>
                
                <div class="product-info__actions">
                    <button onclick="addToCartWithVariant(<%= product.id %>)" class="btn product-info__action-btn product-info__action-btn--cart">
                        🛒 Thêm vào giỏ hàng
                    </button>
                    <button onclick="buyNowWithVariant(<%= product.id %>)" class="product-info__action-btn product-info__action-btn--buy">
                        ⚡ Mua ngay
                    </button>
                </div>
                
                <div class="product-info__benefits">
                    <p class="product-info__benefit">
                        <span>✅</span> Miễn phí vận chuyển với đơn từ 500.000đ
                    </p>
                    <p class="product-info__benefit">
                        <span>🔄</span> Đổi trả miễn phí trong 30 ngày
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="/js/main.js"></script>
<script src="/js/product-detail.js"></script>
<script>
// Initialize gallery with product images
initProductGallery([<% if (product.images && product.images.length > 0) { product.images.forEach((img, i) => { %>'<%= img.image_url %>'<% if (i < product.images.length - 1) { %>, <% } }); } %>]);
</script>

<%- include('../partials/footer') %>
