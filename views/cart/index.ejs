<%# Template EJS render giỏ hàng index cho storefront hoặc tài khoản người dùng. %>
<%- include('../partials/header') %>

<link rel="stylesheet" href="/css/cart.css">

<%
    const cartSettings = typeof storefrontSettings !== 'undefined' && storefrontSettings ? storefrontSettings : {};
    const cartFreeShippingMinAmount = Number.isInteger(Number.parseInt(cartSettings.free_shipping_min_amount, 10))
        ? Math.max(0, Number.parseInt(cartSettings.free_shipping_min_amount, 10))
        : 500000;
    const cartShippingFeeAmount = Number.isInteger(Number.parseInt(cartSettings.shipping_fee_amount, 10))
        ? Math.max(0, Number.parseInt(cartSettings.shipping_fee_amount, 10))
        : 30000;
%>

<!-- ===== Trang giỏ hàng ===== -->
<div class="cart-page page-shell">
    <div class="container">
        <section class="page-intro page-intro--compact">
            <h1 class="page-intro__title page-intro__title-inline">
                <span>Giỏ hàng</span>
                <span class="page-intro__slash">/</span>
                <span>Giỏ hàng của bạn</span>
            </h1>
        </section>

        <% if (!cart || !cart.items || cart.items.length === 0) { %>
            <div class="cart-empty">
                <h2 class="cart-empty__title">Giỏ hàng đang trống</h2>
                <p class="cart-empty__text">Thêm sản phẩm vào giỏ để tiếp tục mua sắm.</p>
                <a href="/products" class="btn btn-primary cart-empty__btn">Tiếp tục mua sắm</a>
            </div>
        <% } else { %>
            <div class="cart-grid">
                <div class="cart-items-container">
                    <div class="cart-select-all">
                        <label>
                            <input type="checkbox" id="selectAll" class="cart-select-all__checkbox">
                            <span class="cart-select-all__text">Chọn tất cả (<%= cart.items.length %> sản phẩm)</span>
                        </label>
                    </div>

                    <div id="cartItems">
                        <% cart.items.forEach((item, index) => { %>
                            <div class="cart-item <%= index < cart.items.length - 1 ? 'cart-item--bordered' : '' %>" data-item-id="<%= item.id %>" data-price="<%= item.subtotal %>">
                                <div class="cart-item__checkbox-wrapper">
                                    <input type="checkbox" class="item-checkbox cart-item__checkbox" value="<%= item.id %>" data-price="<%= item.subtotal %>">
                                </div>

                                <div class="cart-item__image">
                                    <% if (item.product_image) { %>
                                        <img src="<%= item.product_image %>" alt="<%= item.product_name %>">
                                    <% } else { %>
                                        <div class="cart-item__image-placeholder">WF</div>
                                    <% } %>
                                </div>

                                <div class="cart-item__info">
                                    <a href="/products/<%= item.product_slug %>" class="cart-item__name"><%= item.product_name %></a>
                                    <% if (item.size || item.color) { %>
                                        <p class="cart-item__variant">
                                            <% if (item.size) { %>Size: <%= item.size %><% } %>
                                            <% if (item.color) { %> | Màu: <%= item.color %><% } %>
                                        </p>
                                    <% } %>
                                    <p class="cart-item__unit-price"><%= item.unit_price.toLocaleString('vi-VN') %>đ / sản phẩm</p>
                                </div>

                                <div class="cart-item__quantity">
                                    <button data-cart-action="update-quantity" data-item-id="<%= item.id %>" data-next-quantity="<%= item.quantity - 1 %>" class="cart-item__qty-btn">-</button>
                                    <input
                                        type="number"
                                        value="<%= item.quantity %>"
                                        min="1"
                                        step="1"
                                        inputmode="numeric"
                                        enterkeyhint="done"
                                        data-item-id="<%= item.id %>"
                                        data-current-quantity="<%= item.quantity %>"
                                        class="cart-item__qty-input"
                                        aria-label="Số lượng sản phẩm <%= item.product_name %>"
                                    >
                                    <button data-cart-action="update-quantity" data-item-id="<%= item.id %>" data-next-quantity="<%= item.quantity + 1 %>" class="cart-item__qty-btn">+</button>
                                </div>

                                <div class="cart-item__subtotal">
                                    <p class="cart-item__subtotal-price"><%= item.subtotal.toLocaleString('vi-VN') %>đ</p>
                                </div>

                                <button data-cart-action="remove-item" data-item-id="<%= item.id %>" class="cart-item__remove" aria-label="Xóa sản phẩm">&times;</button>
                            </div>
                        <% }) %>
                    </div>
                </div>

                <div class="cart-summary-wrapper">
                    <div class="cart-summary">
                        <h3 class="cart-summary__title">Tóm tắt đơn hàng</h3>

                        <div class="cart-summary__rows">
                            <div class="cart-summary__row">
                                <span class="cart-summary__label">Sản phẩm đã chọn</span>
                                <span id="selectedCount" class="cart-summary__value">0</span>
                            </div>
                            <div class="cart-summary__row">
                                <span class="cart-summary__label">Tạm tính</span>
                                <span id="selectedSubtotal" class="cart-summary__value">0đ</span>
                            </div>
                            <div class="cart-summary__row">
                                <span class="cart-summary__label">Phí vận chuyển</span>
                                <span id="shippingFee" class="cart-summary__value"><%= cartShippingFeeAmount === 0 ? 'Miễn phí' : cartShippingFeeAmount.toLocaleString('vi-VN') + 'đ' %></span>
                            </div>
                        </div>

                        <div class="cart-summary__total">
                            <span class="cart-summary__total-label">Tổng cộng</span>
                            <span id="selectedTotal" class="cart-summary__total-value">0đ</span>
                        </div>

                        <button id="checkoutBtn" type="button" disabled class="cart-summary__checkout-btn" data-cart-action="checkout-selected">
                            Thanh toán (<span id="checkoutCount">0</span>)
                        </button>

                        <a href="/products" class="cart-summary__continue-btn">Tiếp tục mua sắm</a>
                    </div>
                </div>
            </div>
        <% } %>
    </div>
</div>

<script type="application/json" id="cartPricingConfig"><%- JSON.stringify({
    freeShippingMinAmount: cartFreeShippingMinAmount,
    shippingFeeAmount: cartShippingFeeAmount
}) %></script>
<script src="/js/cart.js"></script>

<%- include('../partials/footer') %>
