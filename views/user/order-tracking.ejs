<%# Template EJS render người dùng đơn hàng theo dõi đơn hàng cho storefront hoặc tài khoản người dùng. %>
<%- include('../partials/header') %>

<link rel="stylesheet" href="/css/orders.css">
<link rel="stylesheet" href="/css/tracking.css">

<%
    const shipment = order.shipment || {};
    const trackingEvents = Array.isArray(order.tracking_events) ? order.tracking_events : [];
    const currentReturnRequest = typeof returnRequest !== 'undefined' ? returnRequest : null;
    const currentReturnFeedback = typeof returnFeedback !== 'undefined' ? returnFeedback : null;
    const currentReceivedFeedback = typeof receivedFeedback !== 'undefined' ? receivedFeedback : null;
    const currentCancelFeedback = typeof cancelFeedback !== 'undefined' ? cancelFeedback : null;
    const statusMap = {
        pending_payment: 'Chờ thanh toán',
        pending: 'Chờ xác nhận',
        confirmed: 'Đã xác nhận',
        processing: 'Đang xử lý',
        shipping: 'Đang giao',
        delivered: 'Đã giao',
        completed: 'Đã hoàn thành',
        cancelled: 'Đã hủy'
    };
    const paymentLabels = {
        cod: 'Thanh toán khi nhận hàng',
        vnpay: 'VNPay',
        momo: 'MoMo'
    };
    const progressStepMap = {
        pending_payment: 0,
        pending: 0,
        confirmed: 1,
        processing: 1,
        shipping: 2,
        delivered: 3,
        completed: 3,
        cancelled: 0
    };
    const steps = [
        { key: 'pending', label: 'Tạo đơn' },
        { key: 'confirmed', label: 'Xác nhận' },
        { key: 'shipping', label: 'Vận chuyển' },
        { key: 'completed', label: 'Hoàn tất' }
    ];
    const currentStep = progressStepMap[order.status] ?? 0;
    const hasCoordinates = shipment.current_lat !== null && shipment.current_lat !== undefined && shipment.current_lng !== null && shipment.current_lng !== undefined;
    const mapsUrl = hasCoordinates ? `https://www.google.com/maps?q=${shipment.current_lat},${shipment.current_lng}` : null;
    const isPaymentSettled = order.payment_status === 'paid' || ['delivered', 'completed'].includes(order.status);
    const paymentStatusLabel = isPaymentSettled ? 'Đã thanh toán' : (order.payment_method === 'cod' ? 'COD' : 'Chưa thanh toán');
    const canCancelOrder = ['pending', 'confirmed'].includes(order.status);
%>

<!-- ===== Trang theo dõi vận chuyển đơn hàng ===== -->
<div class="tracking-page page-shell">
    <div class="container tracking-page__container">
        <section class="tracking-hero">
            <div class="tracking-hero__content">
                <p class="tracking-hero__eyebrow">Theo dõi đơn hàng</p>
                <h1 class="tracking-hero__title"><%= order.order_code %></h1>
                <p class="tracking-hero__copy">
                    Trạng thái hiện tại: <strong><%= statusMap[order.status] || order.status %></strong>
                </p>
            </div>
            <div class="tracking-hero__meta">
                <span>Đặt lúc</span>
                <strong><%= new Date(order.created_at).toLocaleString('vi-VN') %></strong>
            </div>
        </section>
        <section class="tracking-card">
            <div class="tracking-progress <%= order.status === 'cancelled' ? 'is-cancelled' : '' %>">
                <% steps.forEach((step, index) => { %>
                    <div class="tracking-progress__step <%= index < currentStep ? 'is-complete' : '' %> <%= index === currentStep && order.status !== 'cancelled' ? 'is-current' : '' %>">
                        <span class="tracking-progress__dot"><%= index + 1 %></span>
                        <span class="tracking-progress__label"><%= step.label %></span>
                    </div>
                <% }) %>
            </div>

            <% if (order.status === 'cancelled') { %>
                <p class="tracking-progress__cancelled-note">Đơn hàng đã bị hủy. Timeline bên dưới vẫn giữ lịch sử cập nhật gần nhất.</p>
            <% } %>
        </section>

        <div class="tracking-layout">
            <section class="tracking-card">
                <div class="tracking-card__header">
                    <h2>Thông tin vận chuyển</h2>
                </div>
                <div class="tracking-info-grid">
                    <div class="tracking-info">
                        <span>Đơn vị vận chuyển</span>
                        <strong><%= shipment.carrier || 'Đang cập nhật' %></strong>
                    </div>
                    <div class="tracking-info">
                        <span>Mã vận đơn</span>
                        <strong><%= shipment.tracking_code || 'Chưa có' %></strong>
                    </div>
                    <div class="tracking-info">
                        <span>Vị trí hiện tại</span>
                        <strong><%= shipment.current_location_text || 'Chưa có cập nhật vị trí' %></strong>
                    </div>
                    <div class="tracking-info">
                        <span>Dự kiến giao</span>
                        <strong><%= shipment.estimated_delivery_at ? new Date(shipment.estimated_delivery_at).toLocaleString('vi-VN') : 'Chưa có ETA' %></strong>
                    </div>
                </div>

                <p class="tracking-info-note">
                    Dữ liệu vận chuyển được cập nhật từ quản trị hoặc đồng bộ từ đơn vị vận chuyển. Nếu mã vận đơn, ETA hay vị trí còn trống, đơn hàng có thể vẫn đang chờ bàn giao cho hãng giao hàng.
                </p>

                <% if (hasCoordinates) { %>
                    <div class="tracking-map-preview">
                        <p>Tọa độ hiện tại: <strong><%= shipment.current_lat %>, <%= shipment.current_lng %></strong></p>
                        <a href="<%= mapsUrl %>" target="_blank" rel="noopener noreferrer" class="btn btn-secondary">Mở vị trí trên bản đồ</a>
                    </div>
                <% } %>

                <% if (shipment.tracking_url) { %>
                    <div class="tracking-map-preview">
                        <a href="<%= shipment.tracking_url %>" target="_blank" rel="noopener noreferrer" class="btn btn-secondary">Tra cứu trên trang vận chuyển</a>
                    </div>
                <% } %>
            </section>

            <aside class="tracking-side">
                <section class="tracking-card">
                    <div class="tracking-card__header">
                        <h2>Địa chỉ nhận hàng</h2>
                    </div>
                    <div class="tracking-address">
                        <strong><%= order.shipping_name %> - <%= order.shipping_phone %></strong>
                        <p><%= order.address_line %><%= order.ward ? ', ' + order.ward : '' %><%= order.district ? ', ' + order.district : '' %>, <%= order.city %></p>
                    </div>
                </section>
                <section class="tracking-card">
                    <div class="tracking-card__header">
                        <h2>Thanh toán</h2>
                    </div>
                    <div class="tracking-info-grid tracking-info-grid--single">
                        <div class="tracking-info">
                            <span>Phương thức</span>
                            <strong><%= paymentLabels[order.payment_method] || order.payment_method %></strong>
                        </div>
                        <div class="tracking-info">
                            <span>Trạng thái</span>
                            <strong><%= paymentStatusLabel %></strong>
                        </div>
                        <div class="tracking-info">
                            <span>Tổng thanh toán</span>
                            <strong><%= (order.final_amount || order.total_amount).toLocaleString('vi-VN') %>đ</strong>
                        </div>
                    </div>
                    <% if (order.status === 'pending_payment' && order.payment_status !== 'paid' && (order.payment_method === 'vnpay' || order.payment_method === 'momo')) { %>
                        <div class="tracking-map-preview">
                            <p>Đơn hàng đang chờ hoàn tất thanh toán.</p>
                            <a href="/orders/<%= order.order_code %>/pay" class="btn btn-primary">Thanh toán ngay</a>
                        </div>
                    <% } %>
                    <% if (canCancelOrder) { %>
                        <div class="tracking-map-preview">
                            <p>Bạn có thể hủy đơn trước khi đơn chuyển sang xử lý giao hàng.</p>
                            <form action="/orders/<%= order.order_code %>/cancel" method="POST" data-confirm-submit data-confirm-message="Bạn chắc chắn muốn hủy đơn hàng này?">
                                <button type="submit" class="btn btn-danger">Hủy đơn hàng</button>
                            </form>
                        </div>
                    <% } %>
                </section>
            </aside>
        </div>

        <% if (currentCancelFeedback === 'success') { %>
            <section class="tracking-card tracking-action-card tracking-action-card--success">
                <p>Đã hủy đơn hàng. Tồn kho và lượt sử dụng voucher đã được hoàn lại.</p>
            </section>
        <% } else if (currentCancelFeedback === 'invalid-status') { %>
            <section class="tracking-card tracking-action-card tracking-action-card--warning">
                <p>Chỉ có thể hủy đơn ở trạng thái Chờ xác nhận hoặc Đã xác nhận.</p>
            </section>
        <% } %>

        <% if (currentReceivedFeedback === 'confirmed') { %>
            <section class="tracking-card tracking-action-card tracking-action-card--success">
                <p>Đã xác nhận nhận hàng. Đơn hàng đã chuyển sang trạng thái hoàn thành.</p>
            </section>
        <% } %>

        <% if (currentReturnFeedback === 'requested') { %>
            <section class="tracking-card tracking-action-card tracking-action-card--success">
                <p>Đã gửi yêu cầu hoàn hàng. Bộ phận quản trị sẽ kiểm tra minh chứng và phản hồi.</p>
            </section>
        <% } else if (currentReturnFeedback) { %>
            <section class="tracking-card tracking-action-card tracking-action-card--warning">
                <p>
                    <% if (currentReturnFeedback === 'missing-reason') { %>
                        Vui lòng nhập lý do hoàn hàng tối thiểu 10 ký tự.
                    <% } else if (currentReturnFeedback === 'missing-media') { %>
                        Vui lòng tải lên hình ảnh hoặc video minh chứng.
                    <% } else if (currentReturnFeedback === 'already-requested') { %>
                        Đơn hàng này đã có yêu cầu hoàn hàng.
                    <% } else if (currentReturnFeedback === 'invalid-status') { %>
                        Chỉ đơn hàng đã giao mới có thể yêu cầu hoàn hàng.
                    <% } else { %>
                        Không thể gửi yêu cầu hoàn hàng. Vui lòng kiểm tra lại tệp minh chứng.
                    <% } %>
                </p>
            </section>
        <% } %>

        <% if (order.status === 'delivered') { %>
            <section class="tracking-card tracking-action-card" id="return-request">
                <div class="tracking-card__header">
                    <h2>Xác nhận sau giao hàng</h2>
                </div>
                <% if (currentReturnRequest) { %>
                    <p class="tracking-info-note">Yêu cầu hoàn hàng của bạn đang ở trạng thái <strong><%= currentReturnRequest.status %></strong>.</p>
                    <div class="tracking-post-delivery-actions tracking-post-delivery-actions--inline">
                        <a href="/orders/<%= order.order_code %>/return-request" class="btn btn-secondary">Xem yêu cầu hoàn hàng</a>
                    </div>
                <% } else { %>
                    <div class="tracking-post-delivery-actions tracking-post-delivery-actions--inline">
                        <form action="/orders/<%= order.order_code %>/confirm-received" method="POST">
                            <button type="submit" class="btn btn-primary">Xác nhận nhận hàng</button>
                        </form>
                        <a href="/orders/<%= order.order_code %>/return-request" class="btn btn-secondary">Yêu cầu hoàn hàng</a>
                    </div>
                <% } %>
            </section>
        <% } %>
        <section class="tracking-card">
            <div class="tracking-card__header">
                <h2>Tiến trình vận chuyển</h2>
            </div>

            <% if (trackingEvents.length > 0) { %>
                <div class="tracking-timeline">
                    <% trackingEvents.forEach((event) => { %>
                        <article class="tracking-event">
                            <div class="tracking-event__dot"></div>
                            <div class="tracking-event__body">
                                <div class="tracking-event__top">
                                    <h3><%= event.title %></h3>
                                    <time><%= new Date(event.event_time).toLocaleString('vi-VN') %></time>
                                </div>
                                <% if (event.description) { %>
                                    <p><%= event.description %></p>
                                <% } %>
                                <% if (event.location_text) { %>
                                    <p><strong>Địa điểm:</strong> <%= event.location_text %></p>
                                <% } %>
                                <% if (event.created_by_name) { %>
                                    <p><strong>Cập nhật bởi:</strong> <%= event.created_by_name %></p>
                                <% } %>
                            </div>
                        </article>
                    <% }) %>
                </div>
            <% } else { %>
                <p class="tracking-empty">Chưa có mốc vận chuyển nào được ghi nhận.</p>
            <% } %>
        </section>

        <div class="confirmation-actions">
            <a href="/orders/history" class="btn btn-secondary">Quay lại lịch sử đơn</a>
            <a href="/orders/<%= order.order_code %>/confirmation" class="btn btn-primary">Xem chi tiết đơn</a>
            <% if (canCancelOrder) { %>
                <form action="/orders/<%= order.order_code %>/cancel" method="POST" data-confirm-submit data-confirm-message="Bạn chắc chắn muốn hủy đơn hàng này?">
                    <button type="submit" class="btn btn-danger">Hủy đơn hàng</button>
                </form>
            <% } %>
        </div>
    </div>
</div>

<script src="/js/order-actions.js"></script>

<%- include('../partials/footer') %>
